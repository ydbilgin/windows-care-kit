<UserControl x:Class="WindowsCareKit.App.Views.UninstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WindowsCareKit.App.Controls;assembly=Suite.App.Abstractions"
             xmlns:mvvm="clr-namespace:WindowsCareKit.App.Mvvm;assembly=Suite.App.Abstractions"
             xmlns:views="clr-namespace:WindowsCareKit.App.Views">
    <UserControl.Resources>
        <mvvm:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <mvvm:ZeroToVisibleConverter x:Key="ZeroToVis" />
        <mvvm:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- ===== DataGrid look, scoped to this view (emerald evidence-row language, 2026-07 UI rollout) =====
             Reuses the Backup.* tokens introduced by the Backup slice — the header/row/rail surfaces read as
             the SAME design system as Backup/ConfirmGate, not a separate look. -->

        <!-- Column header: quiet, faint, no chrome — matches mockup B's thin header row. -->
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Backup.Chrome}" />
            <Setter Property="Foreground" Value="{DynamicResource Backup.Faint}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.Line}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="GridHeaderRight" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <!-- Row container: fixed ~46px height, hover/selected fills from the emerald evidence-row palette. -->
        <Style x:Key="GridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Backup.Ink}" />
            <Setter Property="Height" Value="46" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Backup.CardHi}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Backup.EmWash}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary / secondary buttons — the SAME two-tier hierarchy as Backup's Scan/Run pair, so the one
             action that moves the user forward (Uninstall →) reads as the emerald primary CTA, never a plain
             ghost button indistinguishable from Refresh. -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Backup.Ink}" />
            <Setter Property="Background" Value="{DynamicResource Backup.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.LineStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Backup.CardHi}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Backup.Faint}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{DynamicResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Foreground" Value="{DynamicResource Backup.EmInk}" />
            <Setter Property="Background" Value="{DynamicResource Backup.Primary.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.Primary.Border}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Backup.Primary.Hover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Backup.Primary.HoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{DynamicResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Backup.Ink}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Right-aligned, tabular-figure cell for Size / Installed. -->
        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Backup.Muted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            <!-- tabular-nums: align digits in the size/date columns -->
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style x:Key="SearchTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="{DynamicResource Backup.Card}" />
            <Setter Property="Foreground" Value="{DynamicResource Backup.Ink}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.LineStrong}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource Backup.Faint}"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Text.Length, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ZeroToVis}}"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value="" />
                                    <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark" Property="Opacity" Value="0.45" />
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Backup.Faint}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Row 0: title strip (Backup type scale: H1 24 semibold / subtitle 13 muted) ===== -->
        <StackPanel Grid.Row="0" Margin="24,16,24,0">
            <TextBlock Text="{Binding I18n[uninstall.title]}" Foreground="{DynamicResource Backup.Ink}"
                       FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding I18n[uninstall.subtitle]}" Foreground="{DynamicResource Backup.Muted}"
                       FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0" />
        </StackPanel>

        <!-- ===== Row 1: dense command bar (search + scope + sort + refresh), sits below the active top tab ===== -->
        <Border Grid.Row="1" Background="{DynamicResource Backup.Chrome}" BorderBrush="{DynamicResource Backup.Line}"
                BorderThickness="0,1,0,1" Padding="24,12" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search: refreshes the ICollectionView filter only (never refills the source). -->
                <TextBox Grid.Column="0" MaxWidth="420" HorizontalAlignment="Stretch"
                         Tag="{Binding I18n[common.search]}" ToolTip="{Binding I18n[common.search]}"
                         Style="{StaticResource SearchTextBox}"
                         VerticalContentAlignment="Center"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Trivial scope filter (All / Desktop / Store). Desktop/Store PILLS are deferred (§2). -->
                <ComboBox Grid.Column="1" Width="120" Margin="10,0,0,0" VerticalContentAlignment="Center"
                          SelectedIndex="{Binding ScopeIndex}">
                    <ComboBoxItem Content="{Binding I18n[uninstall.scope.all]}" />
                    <ComboBoxItem Content="{Binding I18n[uninstall.scope.desktop]}" />
                    <ComboBoxItem Content="{Binding I18n[uninstall.scope.store]}" />
                </ComboBox>

                <!-- Sort label (single A→Z order in v1 — name sort is applied at load; placeholder for §2 sort). -->
                <TextBlock Grid.Column="2" Text="{Binding I18n[uninstall.sort]}" Foreground="{DynamicResource Backup.Faint}"
                           FontSize="11.5" VerticalAlignment="Center" Margin="14,0,4,0" />

                <Button Grid.Column="3" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}"
                        Content="{Binding I18n[common.refresh]}" Command="{Binding RefreshCommand}" />
            </Grid>
        </Border>

        <!-- ===== Row 2: full-width content = grid + lean detail pane ===== -->
        <Grid Grid.Row="2" Margin="24,14,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="318" />
            </Grid.ColumnDefinitions>

            <!-- ===== The single virtualized DataGrid (desktop + Store, flat, name-sorted) ===== -->
            <Border Grid.Column="0" Background="{DynamicResource Backup.Card}" BorderBrush="{DynamicResource Backup.Line}"
                    BorderThickness="1" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" Direction="270" ShadowDepth="4" Opacity="0.14" Color="#000000" />
                </Border.Effect>
                <Grid>
                    <DataGrid x:Name="AppsGrid"
                              ItemsSource="{Binding AppsView}"
                              SelectedItem="{Binding SelectedRow}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              IsReadOnly="True" SelectionMode="Single"
                              Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                              Foreground="{DynamicResource Backup.Ink}"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              RowStyle="{StaticResource GridRow}"
                              CellStyle="{StaticResource GridCell}"
                              RowHeight="46"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <!-- İkon 28 (placeholder glyph v1 — no real icon extraction this PR). -->
                            <DataGridTemplateColumn Width="28" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="15" Foreground="{DynamicResource Backup.Muted}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Name * (publisher as a small subline). -->
                            <DataGridTemplateColumn Header="{Binding Data.I18n[uninstall.col.name], Source={StaticResource Proxy}}"
                                                    Width="*" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource Backup.Ink}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Publisher}" Foreground="{DynamicResource Backup.Faint}"
                                                       FontSize="10.5" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Publisher 130 (hidden at narrow widths). -->
                            <DataGridTextColumn x:Name="PublisherColumn"
                                                Header="{Binding Data.I18n[uninstall.col.publisher], Source={StaticResource Proxy}}"
                                                Binding="{Binding Publisher}" Width="130" CanUserSort="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Backup.Muted}" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Boyut 78 (right-aligned, tabular-nums; hidden at narrow widths). -->
                            <DataGridTextColumn x:Name="SizeColumn"
                                                Header="{Binding Data.I18n[uninstall.col.size], Source={StaticResource Proxy}}"
                                                Binding="{Binding SizeDisplay}" Width="78" CanUserSort="False"
                                                HeaderStyle="{StaticResource GridHeaderRight}"
                                                ElementStyle="{StaticResource NumCell}" />

                            <!-- Yükleme 96 (right-aligned). -->
                            <DataGridTextColumn x:Name="InstalledColumn"
                                                Header="{Binding Data.I18n[uninstall.col.installed], Source={StaticResource Proxy}}"
                                                Binding="{Binding InstallDateDisplay}" Width="96" CanUserSort="False"
                                                HeaderStyle="{StaticResource GridHeaderRight}"
                                                ElementStyle="{StaticResource NumCell}" />

                            <!-- Version 78 (hidden at narrow widths). -->
                            <DataGridTextColumn x:Name="VersionColumn"
                                                Header="{Binding Data.I18n[uninstall.col.version], Source={StaticResource Proxy}}"
                                                Binding="{Binding Version}" Width="78" CanUserSort="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Backup.Muted}" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Status 110 (human-language badge; neutral gray / amber, never green — honesty gate,
                                 VM-driven BadgeBrush is untouched by this restyle). -->
                            <DataGridTemplateColumn Header="{Binding Data.I18n[uninstall.col.status], Source={StaticResource Proxy}}"
                                                    Width="110" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BadgeText}" Foreground="{Binding BadgeBrush}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Loading overlay -->
                    <Border Background="{DynamicResource Bg.Scrim.Loading}" CornerRadius="10"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding I18n[uninstall.loading]}" Foreground="{DynamicResource Backup.Muted}"
                                   FontSize="12.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- ===== Lean, info-only detail pane (UI decision §3) — the SAME right-rail treatment as Backup's
                 summary rail: a subtle gradient card, quiet field labels, tabular-adjacent values. ===== -->
            <Border Grid.Column="1" Margin="18,0,0,0" Background="{DynamicResource Backup.Rail.Background}"
                    BorderBrush="{DynamicResource Backup.RailBorder}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <!-- Empty prompt -->
                    <TextBlock Text="{Binding I18n[uninstall.selectPrompt]}" Foreground="{DynamicResource Backup.Muted}"
                               FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="240"
                               Margin="20" TextAlignment="Center" TextWrapping="Wrap"
                               Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}" />

                    <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}" Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="{Binding DetailTitle}" Foreground="{DynamicResource Backup.Ink}"
                                       FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,12" />

                            <TextBlock Text="{Binding I18n[uninstall.detail.publisher]}" Foreground="{DynamicResource Backup.Faint}"
                                       FontSize="11" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DetailPublisher}" Foreground="{DynamicResource Backup.Ink}"
                                       FontSize="12.5" Margin="0,1,0,10" TextWrapping="Wrap" />

                            <TextBlock Text="{Binding I18n[uninstall.detail.version]}" Foreground="{DynamicResource Backup.Faint}"
                                       FontSize="11" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DetailVersion}" Foreground="{DynamicResource Backup.Ink}"
                                       FontSize="12.5" Margin="0,1,0,10" />

                            <StackPanel Visibility="{Binding HasDetailLocation, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding I18n[uninstall.detail.location]}" Foreground="{DynamicResource Backup.Faint}"
                                           FontSize="11" FontWeight="SemiBold" />
                                <Border Background="{DynamicResource Backup.PathBg}" BorderBrush="{DynamicResource Backup.Line}"
                                        BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,3,0,7">
                                    <TextBlock Text="{Binding DetailLocation}" Foreground="{DynamicResource Backup.Muted}"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="11" TextWrapping="Wrap" />
                                </Border>
                                <Button HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}"
                                        Padding="10,4" FontSize="11.5" FontWeight="Normal"
                                        Content="{Binding I18n[uninstall.detail.openLocation]}"
                                        Command="{Binding OpenLocationCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- The single primary action. It STAGES the official-uninstaller / Store-removal flow —
                             the actual delete only runs once the ConfirmGate (or the wizard) is approved, so this
                             reads as the emerald "go look at the plan" CTA, not the final irreversible click. -->
                        <Button Grid.Row="1" Style="{StaticResource PrimaryButton}" Margin="0,14,0,0"
                                HorizontalAlignment="Stretch" Padding="12,9"
                                Content="{Binding I18n[uninstall.detail.remove]}"
                                Command="{Binding UninstallSelectedCommand}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Confirmation gate overlay — the reusable ConfirmGate (UI decision §B2), unchanged from PR-1.
             This drives the EXISTING Sil flows (official / Store removal); the wizard owns its OWN gate. -->
        <controls:ConfirmGate Grid.RowSpan="3" DataContext="{Binding Gate}" />

        <!-- The 4-beat uninstall wizard overlay (PR-4) — opened by the detail-pane "Kaldır →" for a desktop app. -->
        <views:UninstallWizardView Grid.RowSpan="3" DataContext="{Binding Wizard}" />
    </Grid>
</UserControl>
