<Window x:Class="WindowsCareKit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding I18n[app.title]}" Height="720" Width="1100"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg.Window}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 1: quiet brand strip (logo + wordmark + tagline + language selector) -->
        <Border Grid.Row="0" Background="{StaticResource Bg.Panel}" BorderBrush="#221D14"
                BorderThickness="0,0,0,1" Padding="18,0" Height="44">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="19" Height="19" CornerRadius="6" VerticalAlignment="Center"
                        Margin="0,0,11,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F3C97E" Offset="0" />
                            <GradientStop Color="#D29A41" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding I18n[app.title]}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding I18n[app.tagline]}" Style="{StaticResource Faint}"
                               VerticalAlignment="Center" Margin="11,0,0,0" />
                </StackPanel>
                <!-- Language selector: scales to every lang/*.json (English first). -->
                <ComboBox Grid.Column="3" VerticalAlignment="Center" MinWidth="116"
                          VerticalContentAlignment="Center" FontSize="11.5"
                          ToolTip="{Binding I18n[common.language]}"
                          ItemsSource="{Binding I18n.AvailableLanguages}"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding I18n.SelectedCulture, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Row 2: horizontal module tab strip (4 modules + far-right Settings) -->
        <Border Grid.Row="1" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                BorderThickness="0,0,0,1" Height="58">
            <ListBox Style="{StaticResource TopNavList}" ItemContainerStyle="{StaticResource TopNavTab}"
                     ItemsSource="{Binding Nav}" SelectedItem="{Binding SelectedNav}" Padding="10,0,10,0" />
        </Border>

        <!-- Row 3: content, full width -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentContent}" Margin="0" />

        <!-- First-run notice overlay -->
        <Grid Grid.RowSpan="3" Background="#CC0B0906"
              Visibility="{Binding ShowFirstRun, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Card}" MaxWidth="520" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[firstrun.title]}" Style="{StaticResource H1}" />
                    <TextBlock Text="{Binding I18n[firstrun.body]}" Style="{StaticResource Muted}" Margin="0,12,0,18" />
                    <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                            Content="{Binding I18n[firstrun.ok]}" Command="{Binding DismissFirstRunCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
