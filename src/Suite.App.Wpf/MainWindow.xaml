<Window x:Class="WindowsCareKit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding I18n[app.title]}" Height="720" Width="1100"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg.Window}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding I18n[app.title]}" Style="{StaticResource H1}" />
                    <TextBlock Text="{Binding I18n[app.tagline]}" Style="{StaticResource Faint}" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1" VerticalAlignment="Center"
                        Style="{StaticResource GhostButton}"
                        Content="{Binding I18n[common.languageToggle]}"
                        Command="{Binding ToggleLanguageCommand}" />
            </Grid>
        </Border>

        <!-- Body: nav + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                    BorderThickness="0,0,1,0">
                <ListBox Style="{StaticResource NavList}" ItemContainerStyle="{StaticResource NavItem}"
                         ItemsSource="{Binding Nav}" SelectedItem="{Binding SelectedNav}" Margin="0,12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentContent}" Margin="0" />
        </Grid>

        <!-- First-run notice overlay -->
        <Grid Grid.RowSpan="2" Background="#CC0B0906"
              Visibility="{Binding ShowFirstRun, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Card}" MaxWidth="520" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[firstrun.title]}" Style="{StaticResource H1}" />
                    <TextBlock Text="{Binding I18n[firstrun.body]}" Style="{StaticResource Muted}" Margin="0,12,0,18" />
                    <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                            Content="{Binding I18n[firstrun.ok]}" Command="{Binding DismissFirstRunCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
