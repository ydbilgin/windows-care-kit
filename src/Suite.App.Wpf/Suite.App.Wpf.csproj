<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <RootNamespace>WindowsCareKit.App</RootNamespace>
    <AssemblyName>WindowsCareKit</AssemblyName>
    <UseWPF>true</UseWPF>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- App opens as standard user (asInvoker). Elevation is per-action via a helper (spec §3). -->

    <!-- Self-contained folder-publish ZIP target: WindowsCareKit.exe + dependency DLLs
         (incl. Suite.Module.*) beside it (spec §6; prereq for M4 module loader). -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Suite.App.Abstractions\Suite.App.Abstractions.csproj" />
    <ProjectReference Include="..\Suite.Module.Clean\Suite.Module.Clean.csproj" />
    <ProjectReference Include="..\Suite.Module.Install\Suite.Module.Install.csproj" />
    <ProjectReference Include="..\Suite.Module.Restore\Suite.Module.Restore.csproj" />
    <ProjectReference Include="..\Suite.Module.Backup\Suite.Module.Backup.csproj" />
    <ProjectReference Include="..\Suite.Module.Uninstall\Suite.Module.Uninstall.csproj" />
    <ProjectReference Include="..\Suite.Module.Migration\Suite.Module.Migration.csproj" />
    <ProjectReference Include="..\Suite.Core\Suite.Core.csproj" />
    <ProjectReference Include="..\Suite.Win32\Suite.Win32.csproj" />
    <ProjectReference Include="..\Suite.Execution\Suite.Execution.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expose internal helpers (e.g. App.ResolveCulture) to the test project. -->
    <InternalsVisibleTo Include="Suite.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- i18n string tables ship next to the exe. -->
    <Content Include="lang\en.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="lang\tr.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.BannedApiAnalyzers" Version="3.3.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <AdditionalFiles Include="..\..\BannedSymbols.txt" />
  </ItemGroup>

</Project>
