{
  "entries": [
    {
      "id": "vscode-user",
      "enabled": true,
      "profile": ["dev"],
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%APPDATA%\\Code\\User",
      "target": "gelistirici/Code/User",
      "include": ["settings.json", "keybindings.json", "snippets/**", "tasks.json"],
      "exclude": ["workspaceStorage/**", "Cache/**", "CachedData/**", "Code Cache/**", "GPUCache/**", "logs/**"],
      "requiresClosedProcesses": ["Code"],
      "secretHandling": "metadata-only",
      "verify": { "exists": ["settings.json"], "maxSizeMB": 500 },
      "restore": { "order": 40, "mode": "merge-after-install", "notes": "Once VS Code kur." },
      "description": "VS Code kullanici ayarlari (settings, keybindings, snippets, tasks). Cache/workspaceStorage haric."
    },
    {
      "id": "cursor-user",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%APPDATA%\\Cursor\\User",
      "target": "gelistirici/Cursor/User",
      "include": ["settings.json", "keybindings.json", "snippets/**", "tasks.json"],
      "exclude": ["workspaceStorage/**", "globalStorage/**", "Cache/**", "CachedData/**", "Code Cache/**", "GPUCache/**", "logs/**"],
      "requiresClosedProcesses": ["Cursor"],
      "secretHandling": "metadata-only",
      "verify": { "exists": ["settings.json"], "maxSizeMB": 500 },
      "restore": { "order": 40, "mode": "merge-after-install", "notes": "Once Cursor kur. globalStorage opt-in." },
      "description": "Cursor ayarlari. globalStorage (4.9 GB buyuk/riskli state) ayri opt-in girise birakildi."
    },
    {
      "id": "cursor-globalstorage",
      "enabled": false,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%APPDATA%\\Cursor\\User\\globalStorage",
      "target": "gelistirici/Cursor/User/globalStorage",
      "include": [],
      "exclude": ["Cache/**", "GPUCache/**"],
      "requiresClosedProcesses": ["Cursor"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 6000 },
      "restore": { "order": 41, "mode": "merge-after-install", "notes": "Buyuk state (~4.9 GB)." },
      "description": "Cursor globalStorage — extension/AI state + buyuk cache (~4.9 GB). Opt-in.",
      "uiWarning": "Buyuk ve riskli state (~4.9 GB) — gerekmiyorsa kapali birak."
    },
    {
      "id": "jetbrains-config",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%APPDATA%\\JetBrains",
      "target": "gelistirici/JetBrains",
      "include": [],
      "exclude": ["**/plugins/**", "**/workspace/**", "**/event-log-metadata/**", "**/log/**", "**/caches/**"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 500 },
      "restore": { "order": 42, "mode": "merge-after-install", "notes": "options/keymaps/codestyles/templates/tools." },
      "description": "JetBrains ayarlari (options, keymaps, codestyles, templates, tools). plugins/workspace haric."
    },
    {
      "id": "gitconfig",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%USERPROFILE%\\.gitconfig",
      "target": "gelistirici/.gitconfig",
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 1 },
      "restore": { "order": 43, "mode": "merge-after-install", "notes": "Git ayarlari." },
      "description": ".gitconfig (kullanici adi, email, alias'lar)."
    },
    {
      "id": "wslconfig",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T3",
      "method": "copy",
      "source": "%USERPROFILE%\\.wslconfig",
      "target": "gelistirici/.wslconfig",
      "secretHandling": "normal",
      "verify": { "exists": [], "maxSizeMB": 1 },
      "restore": { "order": 44, "mode": "merge-after-install", "notes": "WSL global ayarlari." },
      "description": ".wslconfig (WSL bellek/CPU ayarlari)."
    },
    {
      "id": "powershell-profile",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%USERPROFILE%\\Documents\\PowerShell",
      "target": "gelistirici/Documents/PowerShell",
      "include": [],
      "exclude": ["Modules/**"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 100 },
      "restore": { "order": 45, "mode": "merge-after-install", "notes": "PowerShell 7 profili." },
      "description": "PowerShell 7 profili ve scriptleri."
    },
    {
      "id": "windowspowershell-profile",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%USERPROFILE%\\Documents\\WindowsPowerShell",
      "target": "gelistirici/Documents/WindowsPowerShell",
      "include": [],
      "exclude": ["Modules/**"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 100 },
      "restore": { "order": 45, "mode": "merge-after-install", "notes": "Windows PowerShell 5.1 profili." },
      "description": "Windows PowerShell 5.1 profili ve scriptleri."
    },
    {
      "id": "visual-studio-2022",
      "enabled": false,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T3",
      "method": "copy",
      "source": "%USERPROFILE%\\Documents\\Visual Studio 2022",
      "target": "gelistirici/Documents/Visual Studio 2022",
      "include": [],
      "exclude": ["**/bin/**", "**/obj/**", "**/.vs/**"],
      "secretHandling": "normal",
      "verify": { "exists": [], "maxSizeMB": 5000 },
      "restore": { "order": 46, "mode": "merge-after-install", "notes": "VS 2022 sablonlari/ayarlari." },
      "description": "Visual Studio 2022 belgeleri (sablonlar, kod parcalari). bin/obj/.vs haric."
    },
    {
      "id": "notepadpp-config",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%APPDATA%\\Notepad++",
      "target": "gelistirici/Notepad++",
      "include": [],
      "exclude": ["backup/**"],
      "secretHandling": "normal",
      "verify": { "exists": [], "maxSizeMB": 50 },
      "restore": { "order": 47, "mode": "merge-after-install", "notes": "Notepad++ ayar ve oturum." },
      "description": "Notepad++ ayarlari ve oturumlari."
    },
    {
      "id": "postman-config",
      "enabled": false,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T2",
      "method": "copy",
      "source": "%APPDATA%\\Postman",
      "target": "gelistirici/Postman",
      "include": [],
      "exclude": ["Cache/**", "GPUCache/**", "logs/**", "Code Cache/**"],
      "requiresClosedProcesses": ["Postman"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 500 },
      "restore": { "order": 48, "mode": "merge-after-install", "notes": "Cloud hesabina baglidir; sync varsa gereksiz." },
      "description": "Postman yerel verisi (~128 MB). Cloud sync varsa gerekmez."
    },
    {
      "id": "code-extensions-liste",
      "enabled": true,
      "phase": "backup",
      "category": "gelistirici",
      "tier": "T3",
      "method": "export-cmd",
      "command": "code --list-extensions",
      "target": "gelistirici/code-extensions.txt",
      "secretHandling": "normal",
      "verify": { "exists": [], "maxSizeMB": 1 },
      "restore": { "order": 49, "mode": "reference", "notes": "code --install-extension ... ile yeniden kur." },
      "description": "VS Code eklenti listesi (yeniden kurulum referansi)."
    }
  ]
}
