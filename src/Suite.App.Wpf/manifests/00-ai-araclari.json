      "enabled": true,
      "phase": "backup",
      "category": "ai-araclari",
      "tier": "T2",
      "method": "copy",
      "source": "%USERPROFILE%\\.antigravitycli",
      "target": "ai-araclari/.antigravitycli",
      "include": [],
      "exclude": ["cache/**", "tmp/**", "logs/**"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 200 },
      "restore": { "order": 48, "mode": "merge-after-install", "notes": "Antigravity CLI state." },
      "description": "Antigravity CLI ayarlari (.antigravitycli)."
    }
  ]
