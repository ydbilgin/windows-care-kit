{
  "entries": [
    {
      "id": "claude-home",
      "enabled": true,
      "profile": ["ai-dev"],
      "phase": "backup",
      "category": "ai-araclari",
      "tier": "T2",
      "method": "copy",
      "source": "%USERPROFILE%\\.claude",
      "target": "ai-araclari/.claude",
      "include": [],
      "exclude": ["cache/**", "file-history/**", "shell-snapshots/**", "paste-cache/**", "projects/**"],
      "requiresClosedProcesses": [],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 500 },
      "restore": { "order": 41, "mode": "merge-after-install", "notes": "Claude Code kurulduktan sonra ayarlari merge et." },
      "description": "Claude Code ayarlari ve skill'leri (.claude). Buyuk state haric; projects/** opt-in."
    },
    {
      "id": "claude-projects",
      "enabled": false,
      "phase": "backup",
      "category": "ai-araclari",
      "tier": "T2",
      "method": "copy",
      "source": "%USERPROFILE%\\.claude\\projects",
      "target": "ai-araclari/.claude/projects",
      "include": [],
      "exclude": [],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 4000 },
      "restore": { "order": 42, "mode": "merge-after-install", "notes": "Buyuk konusma state'i (~1.3 GB)." },
      "description": "Claude oturum gecmisi/state (buyuk, ~1.3 GB) — opt-in.",
      "uiWarning": "Buyuk state klasoru; gerekmiyorsa kapali birak."
    },
    {
      "id": "claude-json",
      "enabled": false,
      "phase": "backup",
      "category": "ai-araclari",
      "tier": "T0",
      "method": "copy",
      "source": "%USERPROFILE%\\.claude.json",
      "target": "ai-araclari/.claude.json",
      "secretHandling": "never-read",
      "verify": { "exists": [], "maxSizeMB": 50 },
      "restore": { "order": 43, "mode": "manual", "notes": "Token icerir; en guvenlisi yeniden login." },
      "description": ".claude.json — oturum token'i icerebilir. Esas yol: yeniden login.",
      "uiWarning": "TOKEN/OTURUM ICERIR — varsayilan KAPALI. Acarsan diski paylasma; en guvenlisi format sonrasi yeniden login."
    },
    {
      "id": "codex-home",
      "enabled": true,
      "phase": "backup",
      "category": "ai-araclari",
      "tier": "T2",
      "method": "copy",
      "source": "%USERPROFILE%\\.codex",
      "target": "ai-araclari/.codex",
      "include": [],
      "exclude": ["log/**", "sessions/**", "cache/**"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 200 },
      "restore": { "order": 44, "mode": "merge-after-install", "notes": "auth.json HARIC; yeniden login." },
      "description": "Codex CLI ayarlari (.codex). auth.json ayri opt-in giriste."
    },
    {
      "id": "codex-auth",
      "enabled": false,
      "phase": "backup",
      "category": "ai-araclari",
      "tier": "T0",
      "method": "copy",
      "source": "%USERPROFILE%\\.codex\\auth.json",
      "target": "ai-araclari/.codex/auth.json",
      "secretHandling": "never-read",
      "verify": { "exists": [], "maxSizeMB": 5 },
      "restore": { "order": 45, "mode": "manual", "notes": "Token; codex auth login tercih et." },
      "description": "Codex auth.json — token. Esas yol: codex auth login.",
      "uiWarning": "TOKEN ICERIR — varsayilan KAPALI. Yeniden login daha guvenli."
    },
    {
