      "requiresClosedProcesses": ["firefox"],
      "secretHandling": "metadata-only",
      "verify": { "exists": [], "maxSizeMB": 1000 },
      "restore": { "order": 50, "mode": "merge-after-install", "notes": "Firefox kapaliyken kopyala. Sifreler logins.json+key4.db birlikte (T0)." },
