<UserControl x:Class="WindowsCareKit.App.Views.MigrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Restyled to the emerald evidence-row language (2026-07 UI rollout): Backup.* tokens, two-tier rows,
         a DRY-RUN badge on the capture (dry-run backup) section, and the SAME 3-color risk vocabulary as
         ConfirmGate/Backup for the legend + promise cards (emerald=portable/reversible, amber=needs another
         step, red=manual/cannot-restore — never green for anything that still needs the user).
         Presentation-only — no ViewModel/selection-logic change; Groups/Items keep their existing bindings. -->
    <UserControl.Resources>
        <Style x:Key="MigrationCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Backup.Card}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Direction="270" ShadowDepth="4" Opacity="0.16" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MigrationSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="FontSize" Value="15.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MigrationMeta" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Backup.Faint}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MigrationSecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="Background" Value="{StaticResource Backup.CardHi}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.LineStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7.5" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Backup.Faint}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MigrationPrimaryButton" TargetType="Button" BasedOn="{StaticResource MigrationSecondaryButton}">
            <Setter Property="Foreground" Value="{StaticResource Backup.EmInk}" />
            <Setter Property="Background" Value="{StaticResource Backup.Primary.Background}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.Primary.Border}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Backup.Primary.Hover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MigrationApproveCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box" Width="15" Height="15" CornerRadius="3"
                                    Background="{StaticResource Backup.Card}"
                                    BorderBrush="{StaticResource Backup.EmBorder}" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Data="M3,7 L6,10 L12,4"
                                      Stroke="{StaticResource Backup.EmInk}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource Backup.Em}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Backup.Em}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Capture dry-run row: two-tier, monospace action line only (it IS a literal path/command). -->
        <DataTemplate x:Key="PlanRowTemplate">
            <Border Background="{StaticResource Backup.Row.Background}" BorderBrush="{StaticResource Backup.Line}"
                    BorderThickness="1" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{Binding RiskBrush}" BorderBrush="{Binding RiskBrush}"
                            BorderThickness="1" CornerRadius="999" Padding="7,2" VerticalAlignment="Top" Margin="0,1,10,0">
                        <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource Backup.Ink}"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="12.5" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MigrationMeta}" Margin="0,3,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Detail.Length, Converter={StaticResource PositiveToVis}}" />
                        <TextBlock Text="{Binding Undo}" Style="{StaticResource MigrationMeta}"
                                   Visibility="{Binding Undo.Length, Converter={StaticResource PositiveToVis}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="24,14,24,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,2,0">
            <StackPanel MaxWidth="920" HorizontalAlignment="Center">
                <Border Background="{StaticResource Backup.EmWash}" BorderBrush="{StaticResource Backup.EmBorder}"
                        BorderThickness="1" CornerRadius="999" Padding="12,4" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding I18n[migration.eyebrow]}" Foreground="{StaticResource Backup.Em}"
                               FontSize="10.5" FontWeight="Bold" />
                </Border>
                <TextBlock Text="{Binding I18n[migration.title]}" Foreground="{StaticResource Backup.Ink}"
                           FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0" />
                <TextBlock Text="{Binding I18n[migration.subtitle]}" Foreground="{StaticResource Backup.Muted}"
                           FontSize="13" TextWrapping="Wrap" Margin="0,4,0,0" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- What we can carry: genuinely reversible/portable — emerald is honest here. -->
                    <Border Grid.Column="0" Background="{StaticResource Backup.OkWash}" BorderBrush="{StaticResource Backup.OkBorder}"
                            BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[migration.promise.restore.title]}"
                                       Foreground="{StaticResource Backup.OkFg}" FontWeight="Bold" FontSize="13.5" />
                            <TextBlock Text="{Binding I18n[migration.promise.restore.body]}"
                                       Foreground="{StaticResource Backup.Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <!-- What needs your action: loud red — never softened. -->
                    <Border Grid.Column="2" Background="{StaticResource Backup.Row.Danger}" BorderBrush="{StaticResource Backup.DangerBorder}"
                            BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[migration.promise.manual.title]}"
                                       Foreground="{StaticResource Backup.DangerStrong}" FontWeight="Bold" FontSize="13.5" />
                            <TextBlock Text="{Binding I18n[migration.promise.manual.body]}"
                                       Foreground="{StaticResource Backup.Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource MigrationCard}" Margin="0,14,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding I18n[migration.scan.title]}" Style="{StaticResource MigrationSectionTitle}" />
                                <TextBlock Text="{Binding ProfileSummary}" Style="{StaticResource MigrationMeta}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource MigrationPrimaryButton}"
                                        Content="{Binding I18n[migration.scan.start]}"
                                        Command="{Binding StartScanCommand}" />
                                <Button Style="{StaticResource MigrationSecondaryButton}" Margin="8,0,0,0"
                                        Content="{Binding I18n[migration.scan.cancel]}"
                                        Command="{Binding CancelScanCommand}"
                                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding I18n[migration.scan.running]}" Foreground="{StaticResource Backup.Muted}"
                                   FontSize="12.5" Margin="0,12,0,0"
                                   Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding ScanError}" Foreground="{StaticResource Backup.DangerStrong}"
                                   FontSize="12.5" FontWeight="SemiBold" Margin="0,10,0,0"
                                   Visibility="{Binding ScanError.Length, Converter={StaticResource PositiveToVis}}" />
                        <ItemsControl ItemsSource="{Binding SourceRows}" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Glyph}" Margin="0,0,8,0" FontSize="12.5" />
                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MigrationMeta}" Margin="21,2,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding CeilingText}" Style="{StaticResource MigrationMeta}" Margin="0,12,0,0"
                                   Visibility="{Binding IsScanComplete, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- Legend — the SAME 3-color risk vocabulary as ConfirmGate/Backup. -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,8">
                    <Border Background="{StaticResource Backup.OkWash}" BorderBrush="{StaticResource Backup.OkBorder}" BorderThickness="1"
                            CornerRadius="999" Padding="11,5" Margin="0,0,8,0">
                        <TextBlock Text="{Binding I18n[migration.legend.portable]}" Foreground="{StaticResource Backup.OkFg}" FontSize="12" />
                    </Border>
                    <Border Background="{StaticResource Backup.MedWash}" BorderBrush="{StaticResource Backup.MedBorder}" BorderThickness="1"
                            CornerRadius="999" Padding="11,5" Margin="0,0,8,0">
                        <TextBlock Text="{Binding I18n[migration.legend.step]}" Foreground="{StaticResource Backup.MedFg}" FontSize="12" />
                    </Border>
                    <Border Background="{StaticResource Backup.Row.Danger}" BorderBrush="{StaticResource Backup.DangerBorder}" BorderThickness="1"
                            CornerRadius="999" Padding="11,5">
                        <TextBlock Text="{Binding I18n[migration.legend.manual]}" Foreground="{StaticResource Backup.DangerStrong}" FontSize="12" />
                    </Border>
                </StackPanel>

                <TextBlock Text="{Binding I18n[migration.groups.heading]}" Style="{StaticResource MigrationSectionTitle}"
                           FontSize="14" Margin="0,10,0,10" />
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource MigrationCard}" Padding="0" Margin="0,0,0,12" ClipToBounds="True">
                                <Expander IsExpanded="True" BorderThickness="0" Background="Transparent">
                                    <Expander.Header>
                                        <Grid MinWidth="760" Margin="14,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsThreeState="True" IsChecked="{Binding IsChecked}"
                                                      Style="{StaticResource MigrationApproveCheckBox}"
                                                      IsEnabled="{Binding DataContext.CanSelect, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      VerticalAlignment="Center" Margin="0,0,14,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource Backup.Ink}" FontWeight="Bold" FontSize="14.5" />
                                                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MigrationMeta}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="{StaticResource Backup.CardHi}" BorderBrush="{StaticResource Backup.LineStrong}"
                                                    BorderThickness="1" CornerRadius="999" Padding="10,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CountSummary}" Foreground="{StaticResource Backup.Muted}" FontSize="11.5" />
                                            </Border>
                                        </Grid>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Items}" Margin="14,0,14,12">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource Backup.Row.Background}" BorderBrush="{StaticResource Backup.Line}"
                                                        BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                                  ToolTip="{Binding ForcedSelectionToolTip}"
                                                                  ToolTipService.ShowOnDisabled="True"
                                                                  VerticalAlignment="Top" Margin="0,2,12,0">
                                                            <CheckBox.Style>
                                                                <Style TargetType="CheckBox" BasedOn="{StaticResource MigrationApproveCheckBox}">
                                                                    <Setter Property="IsEnabled" Value="True" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.CanSelect, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                                                            <Setter Property="IsEnabled" Value="False" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsForcedSelected}" Value="True">
                                                                            <Setter Property="IsEnabled" Value="False" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </CheckBox.Style>
                                                        </CheckBox>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Candidate.DisplayName}" Foreground="{StaticResource Backup.Ink}"
                                                                       FontWeight="SemiBold" FontSize="13" />
                                                            <TextBlock Text="{Binding WhatHappens}" Foreground="{StaticResource Backup.Muted}"
                                                                       FontSize="12" TextWrapping="Wrap" Margin="0,3,10,0" />
                                                            <TextBlock Text="{Binding DataContext.I18n[migration.item.forced], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                       Foreground="{StaticResource Backup.DangerStrong}" FontWeight="Bold" FontSize="11" Margin="0,4,0,0"
                                                                       Visibility="{Binding IsForcedSelected, Converter={StaticResource BoolToVis}}" />
                                                        </StackPanel>
                                                        <Border Grid.Column="2" Background="{StaticResource Backup.CardHi}"
                                                                BorderBrush="{StaticResource Backup.LineStrong}" BorderThickness="1"
                                                                CornerRadius="999" Padding="9,4" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding BadgeText}" Foreground="{StaticResource Backup.Ink}" FontWeight="Bold" FontSize="11" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Style="{StaticResource MigrationCard}" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding I18n[migration.preview.title]}" Style="{StaticResource MigrationSectionTitle}" />
                        <TextBlock Text="{Binding I18n[migration.preview.body]}" Style="{StaticResource MigrationMeta}" Margin="0,4,0,10" />
                        <ItemsControl ItemsSource="{Binding CommandPreview}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Cascadia Code, Consolas, Courier New" FontSize="11.5"
                                               Foreground="{StaticResource Code.Fg}" Background="{StaticResource Code.Bg}" Padding="10,7"
                                               TextWrapping="Wrap" Margin="0,0,0,5" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MigrationCard}" Margin="0,14,0,0"
                        Visibility="{Binding HasManualTodo, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding I18n[migration.manual.title]}" Style="{StaticResource MigrationSectionTitle}" />
                        <TextBlock Text="{Binding I18n[migration.manual.body]}" Style="{StaticResource MigrationMeta}" Margin="0,4,0,10" />
                        <ItemsControl ItemsSource="{Binding ManualTodoDisplay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5" Margin="0,3,0,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,20,0,2">
                    <TextBlock Text="{Binding I18n[migration.capture.title]}" Foreground="{StaticResource Backup.Ink}"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{StaticResource Backup.EmWash}" BorderBrush="{StaticResource Backup.EmBorder}"
                            BorderThickness="1" CornerRadius="999" Padding="12,4" Margin="12,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource Backup.Em}" Margin="0,0,8,0" />
                            <TextBlock Foreground="{StaticResource Backup.Em}" FontSize="10.5" FontWeight="Bold">
                                <Run Text="{Binding I18n[common.dryRun.badge], Mode=OneWay}" />
                                <Run Text="{Binding I18n[common.dryRun.caption], Mode=OneWay}"
                                     Foreground="{StaticResource Backup.Muted}" FontSize="11" FontWeight="Normal" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border Style="{StaticResource MigrationCard}" Margin="0,10,0,20">
                    <StackPanel>
                        <TextBlock Text="{Binding I18n[migration.capture.destination]}" Style="{StaticResource MigrationMeta}" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" VerticalContentAlignment="Center" Padding="10,8"
                                     Background="{StaticResource Backup.Card}" Foreground="{StaticResource Backup.Ink}"
                                     BorderBrush="{StaticResource Backup.LineStrong}" BorderThickness="1"
                                     FontFamily="Cascadia Code, Consolas, Courier New" FontSize="12.5"
                                     Text="{Binding PackageDir, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource MigrationSecondaryButton}"
                                    Content="{Binding I18n[migration.capture.chooseFolder]}" Click="ChoosePackageFolder_Click" />
                            <Button Grid.Column="2" Margin="9,0,0,0" Style="{StaticResource MigrationPrimaryButton}"
                                    Content="{Binding I18n[migration.capture.buildPlan]}" Command="{Binding BuildCapturePlanCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding PackageWarning}" Foreground="{StaticResource Backup.DangerStrong}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding PackageWarning.Length, Converter={StaticResource PositiveToVis}}" />
                        <CheckBox IsChecked="{Binding IsPreviewApproved}" Margin="0,12,0,0"
                                  Style="{StaticResource MigrationApproveCheckBox}"
                                  Content="{Binding I18n[migration.capture.approve]}"
                                  Visibility="{Binding HasCapturePlan, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding CaptureSummary}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5" Margin="0,10,0,0"
                                   Visibility="{Binding CaptureSummary.Length, Converter={StaticResource PositiveToVis}}" />

                        <Grid Margin="0,18,0,7" Visibility="{Binding CapturePlanRows.Count, Converter={StaticResource PositiveToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding I18n[migration.capture.plan]}" Style="{StaticResource MigrationMeta}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding CapturePlanRows.Count, Mode=OneWay}" Style="{StaticResource MigrationMeta}" FontWeight="SemiBold" Margin="8,0,8,0" />
                            <Border Grid.Column="2" Height="1" Background="{StaticResource Backup.Line}" VerticalAlignment="Center" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding CapturePlanRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                        <Grid Margin="0,18,0,7" Visibility="{Binding CaptureSkippedRows.Count, Converter={StaticResource PositiveToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding I18n[migration.capture.skipped]}" Style="{StaticResource MigrationMeta}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding CaptureSkippedRows.Count, Mode=OneWay}" Style="{StaticResource MigrationMeta}" FontWeight="SemiBold" Margin="8,0,8,0" />
                            <Border Grid.Column="2" Height="1" Background="{StaticResource Backup.Line}" VerticalAlignment="Center" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding CaptureSkippedRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                        <Grid Margin="0,18,0,7" Visibility="{Binding HasCaptureResults, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding I18n[migration.capture.results]}" Style="{StaticResource MigrationMeta}" FontWeight="SemiBold" />
                            <Border Grid.Column="1" Height="1" Background="{StaticResource Backup.Line}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding CaptureResultRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{StaticResource Backup.Rail.Background}" BorderBrush="{StaticResource Backup.RailBorder}"
                BorderThickness="1,1,1,0" Padding="16,12">
            <Grid MaxWidth="920" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource MigrationSecondaryButton}" Content="{Binding I18n[migration.button.recommended]}"
                            Command="{Binding SelectRecommendedCommand}" />
                    <Button Style="{StaticResource MigrationSecondaryButton}" Margin="8,0,0,0"
                            Content="{Binding I18n[migration.button.clearOptional]}"
                            Command="{Binding ClearOptionalCommand}" />
                    <Button Style="{StaticResource MigrationSecondaryButton}" Margin="8,0,0,0"
                            Content="{Binding I18n[migration.button.preview]}"
                            Command="{Binding PreviewCommandsCommand}" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding SelectedSummary}" Foreground="{StaticResource Backup.Ink}" FontWeight="Bold" FontSize="13"
                           VerticalAlignment="Center" Margin="16,0" />
                <Button Grid.Column="3" Style="{StaticResource MigrationPrimaryButton}"
                        Content="{Binding I18n[migration.capture.run]}"
                        Command="{Binding RunCaptureCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
