<UserControl x:Class="WindowsCareKit.App.Views.MigrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="PlanRowTemplate">
            <Border Background="{StaticResource Bg.PanelAlt}" BorderBrush="{StaticResource Border.Soft}"
                    BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{Binding RiskBrush}" CornerRadius="4"
                            Padding="6,2" VerticalAlignment="Top" Margin="0,1,10,0">
                        <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource Text}"
                                   FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Faint}" Margin="0,2,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Undo}" Style="{StaticResource Faint}"
                                   Visibility="{Binding Undo.Length, Converter={StaticResource PositiveToVis}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="900" HorizontalAlignment="Center">
                <TextBlock Text="{Binding I18n[migration.eyebrow]}" Foreground="{StaticResource Gold}"
                           FontWeight="Bold" FontSize="11" />
                <TextBlock Text="{Binding I18n[migration.title]}" Style="{StaticResource H1}" Margin="0,4,0,0" />
                <TextBlock Text="{Binding I18n[migration.subtitle]}" Style="{StaticResource Muted}"
                           FontSize="14" Margin="0,4,0,0" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[migration.promise.restore.title]}"
                                       Foreground="{StaticResource Success}" FontWeight="Bold" />
                            <TextBlock Text="{Binding I18n[migration.promise.restore.body]}"
                                       Style="{StaticResource Muted}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[migration.promise.manual.title]}"
                                       Foreground="{StaticResource Danger}" FontWeight="Bold" />
                            <TextBlock Text="{Binding I18n[migration.promise.manual.body]}"
                                       Style="{StaticResource Muted}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding I18n[migration.scan.title]}" Style="{StaticResource H2}" />
                                <TextBlock Text="{Binding ProfileSummary}" Style="{StaticResource Faint}" Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource GhostButton}"
                                        Content="{Binding I18n[migration.scan.start]}"
                                        Command="{Binding StartScanCommand}" />
                                <Button Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                                        Content="{Binding I18n[migration.scan.cancel]}"
                                        Command="{Binding CancelScanCommand}"
                                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding I18n[migration.scan.running]}" Style="{StaticResource Muted}"
                                   Margin="0,10,0,0"
                                   Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding ScanError}" Foreground="{StaticResource Danger}" Margin="0,8,0,0"
                                   Visibility="{Binding ScanError.Length, Converter={StaticResource PositiveToVis}}" />
                        <ItemsControl ItemsSource="{Binding SourceRows}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Glyph}" Margin="0,0,7,0" />
                                            <TextBlock Text="{Binding Text}" Style="{StaticResource Muted}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Faint}" Margin="22,0,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding CeilingText}" Style="{StaticResource Faint}" Margin="0,10,0,0"
                                   Visibility="{Binding IsScanComplete, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,8">
                    <Border Background="#173322" BorderBrush="{StaticResource Success}" BorderThickness="1"
                            CornerRadius="12" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Text="{Binding I18n[migration.legend.portable]}" Foreground="{StaticResource Success}" />
                    </Border>
                    <Border Background="#332A16" BorderBrush="{StaticResource Gold}" BorderThickness="1"
                            CornerRadius="12" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Text="{Binding I18n[migration.legend.step]}" Foreground="{StaticResource Gold}" />
                    </Border>
                    <Border Background="#351D1D" BorderBrush="{StaticResource Danger}" BorderThickness="1"
                            CornerRadius="12" Padding="10,5">
                        <TextBlock Text="{Binding I18n[migration.legend.manual]}" Foreground="{StaticResource Danger}" />
                    </Border>
                </StackPanel>

                <TextBlock Text="{Binding I18n[migration.groups.heading]}" Style="{StaticResource H2}"
                           Margin="0,8,0,10" />
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander IsExpanded="True" Margin="0,0,0,10">
                                <Expander.Header>
                                    <Grid MinWidth="760" Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsThreeState="True" IsChecked="{Binding IsChecked}"
                                                  IsEnabled="{Binding DataContext.CanSelect, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" />
                                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Faint}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding CountSummary}" Style="{StaticResource Faint}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                                    </Grid>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource Bg.PanelAlt}" BorderBrush="{StaticResource Border.Soft}"
                                                    BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                              IsEnabled="{Binding DataContext.CanSelect, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              VerticalAlignment="Top" Margin="0,3,12,0" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Candidate.DisplayName}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding WhatHappens}" Style="{StaticResource Muted}" Margin="0,2,10,0" />
                                                        <TextBlock Text="{Binding DataContext.I18n[migration.item.forced], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   Foreground="{StaticResource Danger}" FontWeight="Bold" FontSize="11"
                                                                   Visibility="{Binding IsForcedSelected, Converter={StaticResource BoolToVis}}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="2" Background="{StaticResource Bg.Card}"
                                                            BorderBrush="{StaticResource Border.Gold}" BorderThickness="1"
                                                            CornerRadius="11" Padding="9,4" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="11" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Style="{StaticResource Card}" Margin="0,6,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding I18n[migration.preview.title]}" Style="{StaticResource H2}" />
                        <TextBlock Text="{Binding I18n[migration.preview.body]}" Style="{StaticResource Faint}" Margin="0,4,0,8" />
                        <ItemsControl ItemsSource="{Binding CommandPreview}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                               Foreground="#CFE0FF" Background="#0F1830" Padding="10,6"
                                               TextWrapping="Wrap" Margin="0,0,0,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,10,0,20"
                        Visibility="{Binding HasManualTodo, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding I18n[migration.manual.title]}" Style="{StaticResource H2}" />
                        <TextBlock Text="{Binding I18n[migration.manual.body]}" Style="{StaticResource Faint}" Margin="0,4,0,8" />
                        <ItemsControl ItemsSource="{Binding ManualTodoDisplay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,10,0,20">
                    <StackPanel>
                        <TextBlock Text="{Binding I18n[migration.capture.title]}" Style="{StaticResource H2}" />
                        <TextBlock Text="{Binding I18n[migration.capture.destination]}" Style="{StaticResource Faint}"
                                   Margin="0,4,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" VerticalContentAlignment="Center"
                                     Text="{Binding PackageDir, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                                    Content="{Binding I18n[migration.capture.chooseFolder]}"
                                    Click="ChoosePackageFolder_Click" />
                            <Button Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                                    Content="{Binding I18n[migration.capture.buildPlan]}"
                                    Command="{Binding BuildCapturePlanCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding PackageWarning}" Foreground="{StaticResource Danger}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding PackageWarning.Length, Converter={StaticResource PositiveToVis}}" />
                        <CheckBox IsChecked="{Binding IsPreviewApproved}" Margin="0,10,0,0"
                                  Content="{Binding I18n[migration.capture.approve]}"
                                  Visibility="{Binding HasCapturePlan, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding CaptureSummary}" Style="{StaticResource Muted}" Margin="0,8,0,0" />

                        <TextBlock Text="{Binding I18n[migration.capture.plan]}" Style="{StaticResource H2}"
                                   Margin="0,16,0,8"
                                   Visibility="{Binding CapturePlanRows.Count, Converter={StaticResource PositiveToVis}}" />
                        <ItemsControl ItemsSource="{Binding CapturePlanRows}"
                                      ItemTemplate="{StaticResource PlanRowTemplate}" />

                        <TextBlock Text="{Binding I18n[migration.capture.skipped]}" Style="{StaticResource H2}"
                                   Margin="0,16,0,8"
                                   Visibility="{Binding CaptureSkippedRows.Count, Converter={StaticResource PositiveToVis}}" />
                        <ItemsControl ItemsSource="{Binding CaptureSkippedRows}"
                                      ItemTemplate="{StaticResource PlanRowTemplate}" />

                        <TextBlock Text="{Binding I18n[migration.capture.results]}" Style="{StaticResource H2}"
                                   Margin="0,16,0,8"
                                   Visibility="{Binding HasCaptureResults, Converter={StaticResource BoolToVis}}" />
                        <ItemsControl ItemsSource="{Binding CaptureResultRows}"
                                      ItemTemplate="{StaticResource PlanRowTemplate}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                BorderThickness="1,1,1,0" Padding="14,10">
            <Grid MaxWidth="900" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}" Content="{Binding I18n[migration.button.recommended]}"
                            Command="{Binding SelectRecommendedCommand}" />
                    <Button Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                            Content="{Binding I18n[migration.button.clearOptional]}"
                            Command="{Binding ClearOptionalCommand}" />
                    <Button Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                            Content="{Binding I18n[migration.button.preview]}"
                            Command="{Binding PreviewCommandsCommand}" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding SelectedSummary}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="16,0" />
                <Button Grid.Column="3" Style="{StaticResource GhostButton}"
                        Content="{Binding I18n[migration.capture.run]}"
                        Command="{Binding RunCaptureCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
