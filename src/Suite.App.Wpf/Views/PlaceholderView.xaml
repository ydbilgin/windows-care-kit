<UserControl x:Class="WindowsCareKit.App.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Border Style="{StaticResource Card}" MaxWidth="520" VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="{Binding Title}" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding I18n[placeholder.body]}" Style="{StaticResource Muted}"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
