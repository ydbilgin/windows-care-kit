<UserControl x:Class="WindowsCareKit.App.Views.RestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="PlanRowTemplate">
            <Border Background="{StaticResource Bg.PanelAlt}" BorderBrush="{StaticResource Border.Soft}"
                    BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{Binding RiskBrush}" CornerRadius="4"
                            Padding="6,2" VerticalAlignment="Top" Margin="0,1,10,0">
                        <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource Text}"
                                   FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Faint}" Margin="0,2,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Undo}" Style="{StaticResource Faint}"
                                   Visibility="{Binding Undo.Length, Converter={StaticResource PositiveToVis}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Center">
            <TextBlock Text="{Binding I18n[migration.restore.eyebrow]}" Foreground="{StaticResource Gold}"
                       FontWeight="Bold" FontSize="11" />
            <TextBlock Text="{Binding I18n[migration.restore.title]}" Style="{StaticResource H1}" Margin="0,4,0,0" />
            <TextBlock Text="{Binding I18n[migration.restore.subtitle]}" Style="{StaticResource Muted}"
                       FontSize="14" Margin="0,4,0,0" />

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[migration.restore.packageFolder]}" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding I18n[migration.restore.packageHint]}" Style="{StaticResource Faint}"
                               Margin="0,4,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" VerticalContentAlignment="Center"
                                 Text="{Binding PackageDir, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                                Content="{Binding I18n[migration.restore.chooseFolder]}"
                                Click="ChoosePackageFolder_Click" />
                        <Button Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                                Content="{Binding I18n[migration.restore.buildPlan]}"
                                Command="{Binding LoadAndPreviewCommand}" />
                    </Grid>

                    <TextBlock Text="{Binding I18n[migration.restore.stateFolder]}" Style="{StaticResource Faint}"
                               Margin="0,12,0,4" />
                    <TextBox VerticalContentAlignment="Center"
                             Text="{Binding StateDir, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="{Binding StateFilePath}" Style="{StaticResource Faint}" Margin="0,4,0,0"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding PackageWarning}" Foreground="{StaticResource Danger}"
                               FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding PackageWarning.Length, Converter={StaticResource PositiveToVis}}" />
                    <TextBlock Text="{Binding RestoreSummary}" Style="{StaticResource Muted}" Margin="0,8,0,0"
                               Visibility="{Binding RestoreSummary.Length, Converter={StaticResource PositiveToVis}}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0"
                    Visibility="{Binding HasPreviewPlan, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[migration.restore.note.title]}" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding I18n[migration.restore.note.body]}" Style="{StaticResource Muted}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0"
                    Visibility="{Binding HasPreviewPlan, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding I18n[migration.restore.plan]}" Style="{StaticResource H2}" />
                            <TextBlock Text="{Binding I18n[migration.restore.planHint]}" Style="{StaticResource Faint}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                                  IsChecked="{Binding IsPreviewApproved}"
                                  Content="{Binding I18n[migration.restore.approve]}" />
                        <Button Grid.Column="2" Margin="12,0,0,0" Style="{StaticResource GhostButton}"
                                Content="{Binding I18n[migration.restore.run]}"
                                Command="{Binding RunRestoreCommand}" />
                    </Grid>

                    <TextBlock Text="{Binding I18n[migration.restore.planRows]}" Style="{StaticResource H2}"
                               Margin="0,16,0,8"
                               Visibility="{Binding HasPlanRows, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{Binding PlanRows}"
                                  ItemTemplate="{StaticResource PlanRowTemplate}" />

                    <TextBlock Text="{Binding I18n[migration.restore.skipped]}" Style="{StaticResource H2}"
                               Margin="0,16,0,8"
                               Visibility="{Binding HasSkippedRows, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{Binding SkippedRows}"
                                  ItemTemplate="{StaticResource PlanRowTemplate}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0"
                    Visibility="{Binding HasPreviewPlan, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[migration.restore.dispositions]}" Style="{StaticResource H2}" />

                    <TextBlock Text="{Binding RestoredDispositionTitle}" Foreground="{StaticResource Success}"
                               FontWeight="Bold" Margin="0,12,0,8"
                               Visibility="{Binding HasRestoredRows, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{Binding RestoredRows}"
                                  ItemTemplate="{StaticResource PlanRowTemplate}" />

                    <TextBlock Text="{Binding I18n[migration.restore.disposition.ReinstallEnqueued]}" Foreground="{StaticResource Gold}"
                               FontWeight="Bold" Margin="0,12,0,8"
                               Visibility="{Binding HasReinstallEnqueuedRows, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{Binding ReinstallEnqueuedRows}"
                                  ItemTemplate="{StaticResource PlanRowTemplate}" />

                    <TextBlock Text="{Binding I18n[migration.restore.disposition.Manual]}" Foreground="{StaticResource Danger}"
                               FontWeight="Bold" Margin="0,12,0,8"
                               Visibility="{Binding HasManualRows, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{Binding ManualRows}"
                                  ItemTemplate="{StaticResource PlanRowTemplate}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0"
                    Visibility="{Binding HasResultRows, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[migration.restore.results]}" Style="{StaticResource H2}" />
                    <ItemsControl ItemsSource="{Binding ResultRows}" Margin="0,8,0,0"
                                  ItemTemplate="{StaticResource PlanRowTemplate}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,20"
                    Visibility="{Binding HasUndoJournalEntries, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding I18n[migration.restore.undo.title]}" Style="{StaticResource H2}" />
                            <TextBlock Text="{Binding I18n[migration.restore.undo.body]}" Style="{StaticResource Faint}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource GhostButton}" Margin="12,0,0,0"
                                Content="{Binding I18n[migration.restore.undo.preview]}"
                                Command="{Binding PreviewUndoCommand}" />
                        <CheckBox Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0"
                                  IsChecked="{Binding IsUndoPreviewApproved}"
                                  Content="{Binding I18n[migration.restore.undo.approve]}" />
                        <Button Grid.Column="3" Style="{StaticResource GhostButton}" Margin="12,0,0,0"
                                Content="{Binding I18n[migration.restore.undo.run]}"
                                Command="{Binding UndoCommand}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding UndoRows}" Margin="0,12,0,0"
                                  Visibility="{Binding HasUndoRows, Converter={StaticResource BoolToVis}}"
                                  ItemTemplate="{StaticResource PlanRowTemplate}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
