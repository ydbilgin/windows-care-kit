<UserControl x:Class="WindowsCareKit.App.Views.RestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Restyled to the emerald evidence-row language (2026-07 UI rollout): Backup.* tokens, two-tier rows,
         a DRY-RUN badge, an emerald custom checkbox for the two explicit approvals (both properties have a
         PUBLIC setter in RestoreViewModel, so a checkbox is a faithful reskin of the existing binding — no
         VM change), and a right-rail summary whose counts PROJECT the live PlanRows/SkippedRows/RestoredRows/
         ManualRows collections (Mode=OneWay). Disposition color stays honest: Restored=emerald(OK),
         ReinstallEnqueued=amber(Med), Manual=red — never green for a disposition that still needs the user. -->
    <UserControl.Resources>
        <Style x:Key="RestoreCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Backup.Card}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Direction="270" ShadowDepth="4" Opacity="0.16" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RestoreSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="FontSize" Value="15.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RestoreMetaText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Backup.Faint}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="RestoreSecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="Background" Value="{StaticResource Backup.CardHi}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.LineStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7.5" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Backup.Faint}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RestorePrimaryButton" TargetType="Button" BasedOn="{StaticResource RestoreSecondaryButton}">
            <Setter Property="Foreground" Value="{StaticResource Backup.EmInk}" />
            <Setter Property="Background" Value="{StaticResource Backup.Primary.Background}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.Primary.Border}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Backup.Primary.Hover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom emerald checkbox, matching Backup's approve checkbox exactly. -->
        <Style x:Key="RestoreApproveCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box" Width="15" Height="15" CornerRadius="3"
                                    Background="{StaticResource Backup.Card}"
                                    BorderBrush="{StaticResource Backup.EmBorder}" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Data="M3,7 L6,10 L12,4"
                                      Stroke="{StaticResource Backup.EmInk}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource Backup.Em}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Backup.Em}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dry-run row: two-tier, monospace action line only. Risk chip unchanged (RiskBrush/RiskText). -->
        <DataTemplate x:Key="PlanRowTemplate">
            <Border Background="{StaticResource Backup.Row.Background}" BorderBrush="{StaticResource Backup.Line}"
                    BorderThickness="1" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{Binding RiskBrush}" BorderBrush="{Binding RiskBrush}"
                            BorderThickness="1" CornerRadius="999" Padding="7,2" VerticalAlignment="Top" Margin="0,1,10,0">
                        <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource Backup.Ink}"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="12.5" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource RestoreMetaText}" Margin="0,3,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Detail.Length, Converter={StaticResource PositiveToVis}}" />
                        <TextBlock Text="{Binding Undo}" Style="{StaticResource RestoreMetaText}"
                                   Visibility="{Binding Undo.Length, Converter={StaticResource PositiveToVis}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24,14,24,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14" MaxWidth="1100" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,2">
                <TextBlock Text="{Binding I18n[migration.restore.title]}" Foreground="{StaticResource Backup.Ink}"
                           FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Border Background="{StaticResource Backup.EmWash}" BorderBrush="{StaticResource Backup.EmBorder}"
                        BorderThickness="1" CornerRadius="999" Padding="12,4" Margin="12,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource Backup.Em}" Margin="0,0,8,0" />
                        <TextBlock Foreground="{StaticResource Backup.Em}" FontSize="10.5" FontWeight="Bold">
                            <Run Text="{Binding I18n[common.dryRun.badge], Mode=OneWay}" />
                            <Run Text="{Binding I18n[common.dryRun.caption], Mode=OneWay}"
                                 Foreground="{StaticResource Backup.Muted}" FontSize="11" FontWeight="Normal" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
            <TextBlock Text="{Binding I18n[migration.restore.subtitle]}" Foreground="{StaticResource Backup.Muted}"
                       FontSize="13" TextWrapping="Wrap" Margin="0,4,0,12" />

            <Border Style="{StaticResource RestoreCard}">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[migration.restore.packageFolder]}" Style="{StaticResource RestoreSectionTitle}" />
                    <TextBlock Text="{Binding I18n[migration.restore.packageHint]}" Style="{StaticResource RestoreMetaText}"
                               Margin="0,4,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" VerticalContentAlignment="Center" Padding="10,8"
                                  Background="{StaticResource Backup.Card}" Foreground="{StaticResource Backup.Ink}"
                                  BorderBrush="{StaticResource Backup.LineStrong}" BorderThickness="1"
                                  FontFamily="Cascadia Code, Consolas, Courier New" FontSize="12.5"
                                  Text="{Binding PackageDir, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource RestoreSecondaryButton}"
                                Content="{Binding I18n[migration.restore.chooseFolder]}" Click="ChoosePackageFolder_Click" />
                        <Button Grid.Column="2" Margin="9,0,0,0" Style="{StaticResource RestorePrimaryButton}"
                                Content="{Binding I18n[migration.restore.buildPlan]}" Command="{Binding LoadAndPreviewCommand}" />
                    </Grid>

                    <TextBlock Text="{Binding I18n[migration.restore.stateFolder]}" Style="{StaticResource RestoreMetaText}"
                               Margin="0,12,0,4" />
                    <TextBox VerticalContentAlignment="Center" Padding="10,8"
                             Background="{StaticResource Backup.Card}" Foreground="{StaticResource Backup.Ink}"
                             BorderBrush="{StaticResource Backup.LineStrong}" BorderThickness="1"
                             FontFamily="Cascadia Code, Consolas, Courier New" FontSize="12.5"
                             Text="{Binding StateDir, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="{Binding StateFilePath}" Style="{StaticResource RestoreMetaText}" Margin="0,4,0,0" />

                    <TextBlock Text="{Binding PackageWarning}" Foreground="{StaticResource Backup.DangerStrong}"
                               FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding PackageWarning.Length, Converter={StaticResource PositiveToVis}}" />
                    <TextBlock Text="{Binding RestoreSummary}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5"
                               Margin="0,8,0,0"
                               Visibility="{Binding RestoreSummary.Length, Converter={StaticResource PositiveToVis}}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" MinHeight="0" Visibility="{Binding HasPreviewPlan, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="292" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,2,0">
                <StackPanel>
                    <Border Style="{StaticResource RestoreCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[migration.restore.note.title]}" Style="{StaticResource RestoreSectionTitle}" />
                            <TextBlock Text="{Binding I18n[migration.restore.note.body]}" Foreground="{StaticResource Backup.Muted}"
                                       FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RestoreCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding I18n[migration.restore.plan]}" Style="{StaticResource RestoreSectionTitle}" />
                                    <TextBlock Text="{Binding I18n[migration.restore.planHint]}" Style="{StaticResource RestoreMetaText}" Margin="0,3,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0"
                                          Style="{StaticResource RestoreApproveCheckBox}"
                                          IsChecked="{Binding IsPreviewApproved}"
                                          Content="{Binding I18n[migration.restore.approve]}" />
                                <Button Grid.Column="2" Margin="14,0,0,0" Style="{StaticResource RestorePrimaryButton}"
                                        Content="{Binding I18n[migration.restore.run]}" Command="{Binding RunRestoreCommand}" />
                            </Grid>

                            <Grid Margin="0,16,0,7" Visibility="{Binding HasPlanRows, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding I18n[migration.restore.planRows]}" Foreground="{StaticResource Backup.Faint}" FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{Binding PlanRows.Count, Mode=OneWay}" Foreground="{StaticResource Backup.Faint}" FontSize="11" FontWeight="SemiBold" Margin="8,0,8,0" />
                                <Border Grid.Column="2" Height="1" Background="{StaticResource Backup.Line}" VerticalAlignment="Center" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding PlanRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                            <Grid Margin="0,16,0,7" Visibility="{Binding HasSkippedRows, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding I18n[migration.restore.skipped]}" Foreground="{StaticResource Backup.Faint}" FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{Binding SkippedRows.Count, Mode=OneWay}" Foreground="{StaticResource Backup.Faint}" FontSize="11" FontWeight="SemiBold" Margin="8,0,8,0" />
                                <Border Grid.Column="2" Height="1" Background="{StaticResource Backup.Line}" VerticalAlignment="Center" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding SkippedRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RestoreCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[migration.restore.dispositions]}" Style="{StaticResource RestoreSectionTitle}" />

                            <!-- Restored: genuinely reversible/complete — emerald is honest here. -->
                            <TextBlock Text="{Binding RestoredDispositionTitle}" Foreground="{StaticResource Backup.OkFg}"
                                       FontWeight="Bold" FontSize="12.5" Margin="0,14,0,8"
                                       Visibility="{Binding HasRestoredRows, Converter={StaticResource BoolToVis}}" />
                            <ItemsControl ItemsSource="{Binding RestoredRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                            <!-- Reinstall-enqueued: needs another step — amber, not emerald. -->
                            <TextBlock Text="{Binding I18n[migration.restore.disposition.ReinstallEnqueued]}" Foreground="{StaticResource Backup.MedFg}"
                                       FontWeight="Bold" FontSize="12.5" Margin="0,14,0,8"
                                       Visibility="{Binding HasReinstallEnqueuedRows, Converter={StaticResource BoolToVis}}" />
                            <ItemsControl ItemsSource="{Binding ReinstallEnqueuedRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                            <!-- Manual: needs the user by hand — loud red, never softened. -->
                            <TextBlock Text="{Binding I18n[migration.restore.disposition.Manual]}" Foreground="{StaticResource Backup.DangerStrong}"
                                       FontWeight="Bold" FontSize="12.5" Margin="0,14,0,8"
                                       Visibility="{Binding HasManualRows, Converter={StaticResource BoolToVis}}" />
                            <ItemsControl ItemsSource="{Binding ManualRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RestoreCard}" Margin="0,0,0,14"
                            Visibility="{Binding HasResultRows, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[migration.restore.results]}" Style="{StaticResource RestoreSectionTitle}" />
                            <ItemsControl ItemsSource="{Binding ResultRows}" Margin="0,10,0,0" ItemTemplate="{StaticResource PlanRowTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RestoreCard}" Margin="0,0,0,20"
                            Visibility="{Binding HasUndoJournalEntries, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding I18n[migration.restore.undo.title]}" Style="{StaticResource RestoreSectionTitle}" />
                                    <TextBlock Text="{Binding I18n[migration.restore.undo.body]}" Style="{StaticResource RestoreMetaText}" Margin="0,4,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource RestoreSecondaryButton}" Margin="14,0,0,0"
                                        Content="{Binding I18n[migration.restore.undo.preview]}" Command="{Binding PreviewUndoCommand}" />
                                <CheckBox Grid.Column="2" VerticalAlignment="Center" Margin="14,0,0,0"
                                          Style="{StaticResource RestoreApproveCheckBox}"
                                          IsChecked="{Binding IsUndoPreviewApproved}"
                                          Content="{Binding I18n[migration.restore.undo.approve]}" />
                                <Button Grid.Column="3" Style="{StaticResource RestorePrimaryButton}" Margin="14,0,0,0"
                                        Content="{Binding I18n[migration.restore.undo.run]}" Command="{Binding UndoCommand}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding UndoRows}" Margin="0,14,0,0"
                                          Visibility="{Binding HasUndoRows, Converter={StaticResource BoolToVis}}"
                                          ItemTemplate="{StaticResource PlanRowTemplate}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right-rail summary: counts PROJECT the live collections (Mode=OneWay). -->
            <Border Grid.Column="1" Background="{StaticResource Backup.Rail.Background}"
                    BorderBrush="{StaticResource Backup.RailBorder}" BorderThickness="1" CornerRadius="10"
                    Padding="16" Margin="18,0,0,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[migration.restore.rail.title]}" Foreground="{StaticResource Backup.Ink}"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding I18n[migration.restore.summary.planned]}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5" />
                        <TextBlock Grid.Column="1" Text="{Binding PlanRows.Count, Mode=OneWay}" Foreground="{StaticResource Backup.Em}"
                                   FontSize="14" FontWeight="Bold" />
                    </Grid>
                    <Border Height="1" Background="{StaticResource Backup.Line}" Margin="0,7,0,7" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding I18n[migration.restore.summary.restored]}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5" />
                        <TextBlock Grid.Column="1" Text="{Binding RestoredRows.Count, Mode=OneWay}" Foreground="{StaticResource Backup.Ink}"
                                   FontSize="14" FontWeight="Bold" />
                    </Grid>
                    <Border Height="1" Background="{StaticResource Backup.Line}" Margin="0,7,0,7" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding I18n[migration.restore.summary.manual]}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5" />
                        <TextBlock Grid.Column="1" Text="{Binding ManualRows.Count, Mode=OneWay}" Foreground="{StaticResource Backup.Ink}"
                                   FontSize="14" FontWeight="Bold" />
                    </Grid>
                    <Border Height="1" Background="{StaticResource Backup.Line}" Margin="0,7,0,7" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding I18n[migration.restore.summary.skipped]}" Foreground="{StaticResource Backup.Muted}" FontSize="12.5" />
                        <TextBlock Grid.Column="1" Text="{Binding SkippedRows.Count, Mode=OneWay}" Foreground="{StaticResource Backup.Ink}"
                                   FontSize="14" FontWeight="Bold" />
                    </Grid>

                    <TextBlock Text="{Binding I18n[migration.restore.summary.package]}" Foreground="{StaticResource Backup.Faint}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,13,0,5" />
                    <Border Background="{StaticResource Backup.PathBg}" BorderBrush="{StaticResource Backup.Line}"
                            BorderThickness="1" CornerRadius="6" Padding="9,7">
                        <TextBlock Text="{Binding PackageDir}" Foreground="{StaticResource Backup.Ink}"
                                   FontFamily="Cascadia Code, Consolas, Courier New" FontSize="11.5" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
