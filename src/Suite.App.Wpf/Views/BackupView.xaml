<UserControl x:Class="WindowsCareKit.App.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Row template shared by the plan / manual / skipped / result lists (mirrors UninstallView). -->
        <DataTemplate x:Key="PlanRowTemplate">
            <Border Background="{StaticResource Bg.PanelAlt}" BorderBrush="{StaticResource Border.Soft}"
                    BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{Binding RiskBrush}" CornerRadius="4"
                            Padding="6,2" VerticalAlignment="Top" Margin="0,1,10,0">
                        <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource Text}"
                                   FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Faint}" Margin="0,2,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Undo}" Style="{StaticResource Faint}"
                                   Visibility="{Binding Undo.Length, Converter={StaticResource PositiveToVis}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{Binding I18n[backup.title]}" Style="{StaticResource H1}" />
            <TextBlock Text="{Binding I18n[backup.subtitle]}" Style="{StaticResource Muted}" Margin="0,2,0,0" />

            <!-- Payload folder picker + actions -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" VerticalContentAlignment="Center"
                         Text="{Binding PayloadDir, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                        Content="{Binding I18n[backup.scan]}" Command="{Binding BuildPlanCommand}" />
                <Button Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                        Content="{Binding I18n[backup.run]}" Command="{Binding ApproveAndRunCommand}" />
            </Grid>

            <!-- Hint + payload-outside-repo warning -->
            <TextBlock Text="{Binding I18n[backup.chooseDir]}" Foreground="{StaticResource Gold.Dim}"
                       FontSize="11.5" Margin="0,6,0,0" />
            <TextBlock Text="{Binding PayloadWarning}" Foreground="{StaticResource Danger}"
                       FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap"
                       Visibility="{Binding PayloadWarning.Length, Converter={StaticResource PositiveToVis}}" />

            <!-- Approve gate + summary -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" IsChecked="{Binding IsPreviewApproved}"
                          VerticalAlignment="Center"
                          Content="{Binding I18n[backup.approve]}" Foreground="{StaticResource Text}"
                          Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}" />
                <TextBlock Grid.Column="1" Text="{Binding Summary}" Style="{StaticResource Muted}"
                           VerticalAlignment="Center" Margin="14,0,0,0" TextTrimming="CharacterEllipsis" />
            </Grid>
        </StackPanel>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Empty prompt -->
                <TextBlock Text="{Binding I18n[backup.empty.prompt]}" Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,40,0,0" MaxWidth="420" TextAlignment="Center"
                           Visibility="{Binding HasPlan, Converter={StaticResource InverseBoolToVis}}" />

                <!-- Dry-run plan -->
                <TextBlock Text="{Binding I18n[backup.report.title]}" Style="{StaticResource H2}"
                           Margin="0,0,0,8"
                           Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}" />
                <ItemsControl ItemsSource="{Binding PlanRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                <!-- Manual to-do (secrets never copied) -->
                <TextBlock Text="{Binding I18n[backup.report.manual]}" Foreground="{StaticResource Gold}"
                           FontSize="13" FontWeight="SemiBold" Margin="0,18,0,8"
                           Visibility="{Binding ManualRows.Count, Converter={StaticResource PositiveToVis}}" />
                <TextBlock Text="{Binding I18n[backup.secret.manual]}" Style="{StaticResource Faint}"
                           Margin="0,0,0,8" TextWrapping="Wrap"
                           Visibility="{Binding ManualRows.Count, Converter={StaticResource PositiveToVis}}" />
                <ItemsControl ItemsSource="{Binding ManualRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                <!-- Skipped -->
                <TextBlock Text="{Binding I18n[backup.report.skipped]}" Style="{StaticResource H2}"
                           Margin="0,18,0,8"
                           Visibility="{Binding SkippedRows.Count, Converter={StaticResource PositiveToVis}}" />
                <ItemsControl ItemsSource="{Binding SkippedRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                <!-- Results (after run) -->
                <TextBlock Text="{Binding I18n[backup.report.copied]}" Foreground="{StaticResource Success}"
                           FontSize="13" FontWeight="SemiBold" Margin="0,18,0,8"
                           Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}" />
                <ItemsControl ItemsSource="{Binding ResultRows}" ItemTemplate="{StaticResource PlanRowTemplate}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
