<UserControl x:Class="WindowsCareKit.App.Views.UninstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WindowsCareKit.App.Controls"
             xmlns:views="clr-namespace:WindowsCareKit.App.Views">
    <UserControl.Resources>
        <!-- ===== DataGrid look, scoped to this view (Strongbox tokens) ===== -->

        <!-- Column header: quiet, faint, no chrome — matches mockup B's thin header row. -->
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Bg.Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text.Faint}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource Border.Soft}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="GridHeaderRight" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <!-- Row container: fixed ~46px height, hover/selected fills from the Strongbox palette. -->
        <Style x:Key="GridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Height" Value="46" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Bg.Row.Hover}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Bg.Row.Selected}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Right-aligned, tabular-figure cell for Boyut / Yükleme. -->
        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text.Muted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            <!-- tabular-nums: align digits in the size/date columns -->
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Row 0: title strip ===== -->
        <StackPanel Grid.Row="0" Margin="20,16,20,0">
            <TextBlock Text="{Binding I18n[uninstall.title]}" Style="{StaticResource H1}" />
            <TextBlock Text="{Binding I18n[uninstall.subtitle]}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- ===== Row 1: dense command bar (search + scope + sort + refresh), sits below the active top tab ===== -->
        <Border Grid.Row="1" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                BorderThickness="0,1,0,1" Padding="20,10" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search: refreshes the ICollectionView filter only (never refills the source). -->
                <TextBox Grid.Column="0" MaxWidth="420" HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Trivial scope filter (Tümü / Masaüstü / Mağaza). Desktop/Store PILLS are deferred (§2). -->
                <ComboBox Grid.Column="1" Width="120" Margin="10,0,0,0" VerticalContentAlignment="Center"
                          SelectedIndex="{Binding ScopeIndex}">
                    <ComboBoxItem Content="{Binding I18n[uninstall.scope.all]}" />
                    <ComboBoxItem Content="{Binding I18n[uninstall.scope.desktop]}" />
                    <ComboBoxItem Content="{Binding I18n[uninstall.scope.store]}" />
                </ComboBox>

                <!-- Sort label (single A→Z order in v1 — name sort is applied at load; placeholder for §2 sort). -->
                <TextBlock Grid.Column="2" Text="{Binding I18n[uninstall.sort]}" Style="{StaticResource Faint}"
                           VerticalAlignment="Center" Margin="14,0,4,0" />

                <Button Grid.Column="3" Margin="10,0,0,0" Style="{StaticResource GhostButton}"
                        Content="{Binding I18n[common.refresh]}" Command="{Binding RefreshCommand}" />
            </Grid>
        </Border>

        <!-- ===== Row 2: full-width content = grid + lean detail pane ===== -->
        <Grid Grid.Row="2" Margin="20,14,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="318" />
            </Grid.ColumnDefinitions>

            <!-- ===== The single virtualized DataGrid (desktop + Store, flat, name-sorted) ===== -->
            <Border Grid.Column="0" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <DataGrid x:Name="AppsGrid"
                              ItemsSource="{Binding AppsView}"
                              SelectedItem="{Binding SelectedRow}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              IsReadOnly="True" SelectionMode="Single"
                              Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                              Foreground="{StaticResource Text}"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              RowStyle="{StaticResource GridRow}"
                              CellStyle="{StaticResource GridCell}"
                              RowHeight="46"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <!-- İkon 28 (placeholder glyph v1 — no real icon extraction this PR). -->
                            <DataGridTemplateColumn Width="28" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="15" Foreground="{StaticResource Text.Muted}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Ad * (publisher as a small subline). -->
                            <DataGridTemplateColumn Header="{Binding DataContext.I18n[uninstall.col.name], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Width="*" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Publisher}" Style="{StaticResource Faint}"
                                                       FontSize="10.5" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Yayıncı 130 (hidden at narrow widths). -->
                            <DataGridTextColumn x:Name="PublisherColumn"
                                                Header="{Binding DataContext.I18n[uninstall.col.publisher], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding Publisher}" Width="130" CanUserSort="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Text.Muted}" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Boyut 78 (right-aligned, tabular-nums; hidden at narrow widths). -->
                            <DataGridTextColumn x:Name="SizeColumn"
                                                Header="{Binding DataContext.I18n[uninstall.col.size], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding SizeDisplay}" Width="78" CanUserSort="False"
                                                HeaderStyle="{StaticResource GridHeaderRight}"
                                                ElementStyle="{StaticResource NumCell}" />

                            <!-- Yükleme 96 (right-aligned). -->
                            <DataGridTextColumn x:Name="InstalledColumn"
                                                Header="{Binding DataContext.I18n[uninstall.col.installed], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding InstallDateDisplay}" Width="96" CanUserSort="False"
                                                HeaderStyle="{StaticResource GridHeaderRight}"
                                                ElementStyle="{StaticResource NumCell}" />

                            <!-- Sürüm 78 (hidden at narrow widths). -->
                            <DataGridTextColumn x:Name="VersionColumn"
                                                Header="{Binding DataContext.I18n[uninstall.col.version], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding Version}" Width="78" CanUserSort="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Text.Muted}" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Durum 110 (human-language badge; neutral gray / amber, never green). -->
                            <DataGridTemplateColumn Header="{Binding DataContext.I18n[uninstall.col.status], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Width="110" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BadgeText}" Foreground="{Binding BadgeBrush}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Loading overlay -->
                    <Border Background="{StaticResource Bg.Scrim.Loading}" CornerRadius="8"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding I18n[uninstall.loading]}" Style="{StaticResource Muted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- ===== Lean, info-only detail pane (UI decision §3) ===== -->
            <Border Grid.Column="1" Margin="14,0,0,0" Background="{StaticResource Bg.Card}"
                    BorderBrush="{StaticResource Border.Soft}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <!-- Empty prompt -->
                    <TextBlock Text="{Binding I18n[uninstall.selectPrompt]}" Style="{StaticResource Muted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="240"
                               Margin="20" TextAlignment="Center"
                               Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}" />

                    <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}" Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="{Binding DetailTitle}" Style="{StaticResource H2}"
                                       TextWrapping="Wrap" Margin="0,0,0,12" />

                            <TextBlock Text="{Binding I18n[uninstall.detail.publisher]}" Style="{StaticResource Faint}" />
                            <TextBlock Text="{Binding DetailPublisher}" Foreground="{StaticResource Text}"
                                       FontSize="12.5" Margin="0,1,0,10" TextWrapping="Wrap" />

                            <TextBlock Text="{Binding I18n[uninstall.detail.version]}" Style="{StaticResource Faint}" />
                            <TextBlock Text="{Binding DetailVersion}" Foreground="{StaticResource Text}"
                                       FontSize="12.5" Margin="0,1,0,10" />

                            <StackPanel Visibility="{Binding HasDetailLocation, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding I18n[uninstall.detail.location]}" Style="{StaticResource Faint}" />
                                <TextBlock Text="{Binding DetailLocation}" Foreground="{StaticResource Text.Muted}"
                                           FontSize="11.5" Margin="0,1,0,6" TextWrapping="Wrap" />
                                <Button HorizontalAlignment="Left" Style="{StaticResource GhostButton}"
                                        Padding="9,4" FontSize="11.5" FontWeight="Normal"
                                        Content="{Binding I18n[uninstall.detail.openLocation]}"
                                        Command="{Binding OpenLocationCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- The single primary action. For PR-2 it stages the EXISTING official-uninstaller /
                             Store-removal flow (PR-4 swaps in the wizard). -->
                        <Button Grid.Row="1" Style="{StaticResource GhostButton}" Margin="0,14,0,0"
                                HorizontalAlignment="Stretch" Padding="12,9"
                                Content="{Binding I18n[uninstall.detail.remove]}"
                                Command="{Binding UninstallSelectedCommand}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Confirmation gate overlay — the reusable ConfirmGate (UI decision §B2), unchanged from PR-1.
             This drives the EXISTING Sil flows (official / Store removal); the wizard owns its OWN gate. -->
        <controls:ConfirmGate Grid.RowSpan="3" DataContext="{Binding Gate}" />

        <!-- The 4-beat uninstall wizard overlay (PR-4) — opened by the detail-pane "Kaldır →" for a desktop app. -->
        <views:UninstallWizardView Grid.RowSpan="3" DataContext="{Binding Wizard}" />
    </Grid>
</UserControl>
