<UserControl x:Class="WindowsCareKit.App.Views.UninstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Row template shared by the official-uninstaller, leftover, and result lists. -->
        <DataTemplate x:Key="PlanRowTemplate">
            <Border Background="{StaticResource Bg.PanelAlt}" BorderBrush="{StaticResource Border.Soft}"
                    BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{Binding RiskBrush}" CornerRadius="4"
                            Padding="6,2" VerticalAlignment="Top" Margin="0,1,10,0">
                        <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource Text}"
                                   FontSize="13" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Faint}" Margin="0,2,0,0" />
                        <TextBlock Text="{Binding Undo}" Style="{StaticResource Faint}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{Binding I18n[uninstall.title]}" Style="{StaticResource H1}" />
            <TextBlock Text="{Binding I18n[uninstall.subtitle]}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
            <TextBlock Text="{Binding I18n[uninstall.readonlyNotice]}" Foreground="{StaticResource Gold.Dim}"
                       FontSize="11.5" Margin="0,6,0,0" />
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                        Content="{Binding I18n[common.refresh]}" Command="{Binding RefreshCommand}" />
            </Grid>
        </StackPanel>

        <!-- Body: list + detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left column: classic apps list + per-user Store apps list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Apps list -->
                <Grid Grid.Row="0">
                    <ListBox Style="{StaticResource AppList}" ItemContainerStyle="{StaticResource AppItem}"
                             ItemsSource="{Binding Apps}" SelectedItem="{Binding SelectedApp}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                                                   FontSize="13.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Publisher}" Style="{StaticResource Faint}" />
                                            <TextBlock Text="  ·  " Style="{StaticResource Faint}" />
                                            <TextBlock Text="{Binding DisplayVersion}" Style="{StaticResource Faint}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"
                                            Background="#2E2614" CornerRadius="4" Padding="6,2"
                                            Visibility="{Binding IsMachineWide, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding DataContext.I18n[uninstall.elevation], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   Foreground="{StaticResource Gold}" FontSize="10" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Loading overlay -->
                    <Border Background="#AA141009" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding I18n[uninstall.loading]}" Style="{StaticResource Muted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <!-- Per-user Store apps -->
                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock Text="{Binding I18n[uninstall.appx.section]}" Style="{StaticResource Faint}"
                               Margin="0,0,0,6" />
                    <ListBox Style="{StaticResource AppList}" ItemContainerStyle="{StaticResource AppItem}"
                             MaxHeight="180" ItemsSource="{Binding AppxApps}" SelectedItem="{Binding SelectedAppx}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                                               FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding PublisherDisplayName}" Style="{StaticResource Faint}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Margin="0,8,0,0" Style="{StaticResource GhostButton}"
                            Content="{Binding I18n[uninstall.run.appx]}" Command="{Binding RemoveAppxCommand}"
                            Visibility="{Binding HasAppxSelection, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding I18n[uninstall.appx.irreversible]}" Foreground="{StaticResource Danger}"
                               FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                               Visibility="{Binding HasAppxSelection, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>

            <!-- Detail -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <!-- Prompt when nothing is selected -->
                <TextBlock Text="{Binding I18n[uninstall.selectPrompt]}" Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360"
                           TextAlignment="Center"
                           Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <!-- Official uninstaller -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding I18n[uninstall.official.title]}" Style="{StaticResource H2}" />
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                    Content="{Binding I18n[uninstall.run.official]}" Command="{Binding RunOfficialCommand}"
                                    Visibility="{Binding OfficialActions.Count, Converter={StaticResource PositiveToVis}}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding OfficialActions}" ItemTemplate="{StaticResource PlanRowTemplate}" />
                        <TextBlock Text="{Binding I18n[uninstall.official.none]}" Style="{StaticResource Faint}"
                                   Visibility="{Binding OfficialActions.Count, Converter={StaticResource ZeroToVis}}" />

                        <!-- Leftovers -->
                        <Grid Margin="0,18,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding I18n[uninstall.leftovers.title]}" Style="{StaticResource H2}" />
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                    Content="{Binding I18n[uninstall.run.leftovers]}" Command="{Binding RunLeftoverCommand}"
                                    Visibility="{Binding LeftoverActions.Count, Converter={StaticResource PositiveToVis}}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding LeftoverActions}" ItemTemplate="{StaticResource PlanRowTemplate}" />
                        <TextBlock Text="{Binding I18n[uninstall.leftovers.none]}" Style="{StaticResource Faint}"
                                   Visibility="{Binding LeftoverActions.Count, Converter={StaticResource ZeroToVis}}" />

                        <!-- Skipped (protected) -->
                        <TextBlock Text="{Binding I18n[uninstall.leftovers.skippedTitle]}" Foreground="{StaticResource Danger}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,18,0,8"
                                   Visibility="{Binding SkippedActions.Count, Converter={StaticResource PositiveToVis}}" />
                        <ItemsControl ItemsSource="{Binding SkippedActions}" ItemTemplate="{StaticResource PlanRowTemplate}" />

                        <!-- Result of the last run -->
                        <Border Background="{StaticResource Bg.Card}" BorderBrush="{StaticResource Border.Soft}"
                                BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,18,0,0"
                                Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding I18n[uninstall.result.title]}" Style="{StaticResource H2}" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding ResultSummary}" Foreground="{StaticResource Gold}"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding ExecutionResults}" ItemTemplate="{StaticResource PlanRowTemplate}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Confirmation overlay — the explicit approve step before anything runs. -->
                <Border Background="#CC0F0B05"
                        Visibility="{Binding RequiresConfirmation, Converter={StaticResource BoolToVis}}">
                    <Border Background="{StaticResource Bg.Card}" BorderBrush="{StaticResource Gold.Dim}"
                            BorderThickness="1" CornerRadius="12" Padding="22" MaxWidth="460"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding I18n[uninstall.confirm.title]}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource Danger}" />
                            <TextBlock Text="{Binding I18n[uninstall.confirm.body]}" Style="{StaticResource Muted}"
                                       Margin="0,8,0,0" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                <Button Style="{StaticResource GhostButton}"
                                        Content="{Binding I18n[uninstall.confirm.cancel]}" Command="{Binding CancelCommand}" />
                                <Button Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                                        Content="{Binding I18n[uninstall.confirm.approve]}" Command="{Binding ApproveCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
