<UserControl x:Class="WindowsCareKit.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Form screen (not a list/plan): clean sectioned emerald cards, Backup's type scale + spacing rhythm,
         no evidence rows / risk pills (nothing here is destructive). 2026-07 UI rollout. -->
    <UserControl.Resources>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Backup.Card}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Direction="270" ShadowDepth="4" Opacity="0.16" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingsBody" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Backup.Muted}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SettingsMeta" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Backup.Faint}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer Margin="24,14,24,8" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,2">
                <Border Background="{StaticResource Backup.EmWash}" BorderBrush="{StaticResource Backup.EmBorder}"
                        BorderThickness="1" CornerRadius="999" Padding="12,4" VerticalAlignment="Center">
                    <TextBlock Text="{Binding I18n[settings.eyebrow]}" Foreground="{StaticResource Backup.Em}"
                               FontSize="10.5" FontWeight="Bold" />
                </Border>
            </StackPanel>
            <TextBlock Text="{Binding I18n[settings.title]}" Foreground="{StaticResource Backup.Ink}"
                       FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0" />
            <TextBlock Text="{Binding I18n[settings.subtitle]}" Style="{StaticResource SettingsBody}"
                       Margin="0,4,0,0" />

            <Border Style="{StaticResource SettingsCard}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[settings.language.title]}" Style="{StaticResource SettingsSectionTitle}" />
                    <TextBlock Text="{Binding I18n[settings.language.body]}" Style="{StaticResource SettingsMeta}"
                               Margin="0,4,0,12" />
                    <ComboBox MinWidth="200" MaxWidth="280" HorizontalAlignment="Left"
                              VerticalContentAlignment="Center"
                              ToolTip="{Binding I18n[common.language]}"
                              ItemsSource="{Binding I18n.AvailableLanguages}"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding I18n.SelectedCulture, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}" Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[settings.theme.title]}" Style="{StaticResource SettingsSectionTitle}" />
                    <TextBlock Text="{Binding I18n[settings.theme.body]}" Style="{StaticResource SettingsMeta}"
                               Margin="0,4,0,12" />
                    <ComboBox MinWidth="200" MaxWidth="280" HorizontalAlignment="Left"
                              VerticalContentAlignment="Center"
                              ToolTip="{Binding I18n[settings.theme.title]}"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedValuePath="Theme"
                              SelectedValue="{Binding SelectedTheme, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding ThemeStatusText}" Style="{StaticResource SettingsMeta}"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}" Margin="0,14,0,20">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[settings.about.title]}" Style="{StaticResource SettingsSectionTitle}" />
                    <TextBlock Text="{Binding I18n[settings.about.body]}" Style="{StaticResource SettingsMeta}"
                               Margin="0,4,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding I18n[settings.about.app]}"
                                   Style="{StaticResource SettingsMeta}" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding I18n[app.title]}"
                                   Foreground="{StaticResource Backup.Ink}" FontSize="12.5" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding I18n[settings.about.version]}"
                                   Style="{StaticResource SettingsMeta}" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Version}"
                                   Foreground="{StaticResource Backup.Ink}" FontSize="12.5"
                                   FontFamily="Cascadia Code, Consolas, Courier New" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding I18n[settings.about.license]}"
                                   Style="{StaticResource SettingsMeta}" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding License}"
                                   Foreground="{StaticResource Backup.Ink}" FontSize="12.5" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding I18n[settings.about.repository]}"
                                   Style="{StaticResource SettingsMeta}" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" FontSize="12.5">
                            <Hyperlink NavigateUri="{Binding RepositoryUrl}"
                                       Foreground="{StaticResource Backup.Em}"
                                       RequestNavigate="ExternalLink_RequestNavigate">
                                <Run Text="{Binding I18n[settings.about.repositoryLink], Mode=OneWay}" />
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding I18n[settings.about.releases]}"
                                   Style="{StaticResource SettingsMeta}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="4" Grid.Column="1" FontSize="12.5">
                            <Hyperlink NavigateUri="{Binding ReleasesUrl}"
                                       Foreground="{StaticResource Backup.Em}"
                                       RequestNavigate="ExternalLink_RequestNavigate">
                                <Run Text="{Binding I18n[settings.about.releasesLink], Mode=OneWay}" />
                            </Hyperlink>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
