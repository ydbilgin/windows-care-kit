<UserControl x:Class="WindowsCareKit.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Center">
            <TextBlock Text="{Binding I18n[settings.eyebrow]}" Foreground="{StaticResource Gold}"
                       FontWeight="Bold" FontSize="11" />
            <TextBlock Text="{Binding I18n[settings.title]}" Style="{StaticResource H1}" Margin="0,4,0,0" />
            <TextBlock Text="{Binding I18n[settings.subtitle]}" Style="{StaticResource Muted}"
                       FontSize="14" Margin="0,4,0,0" />

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[settings.language.title]}" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding I18n[settings.language.body]}" Style="{StaticResource Faint}"
                               Margin="0,4,0,10" />
                    <ComboBox MinWidth="180" MaxWidth="260" HorizontalAlignment="Left"
                              VerticalContentAlignment="Center"
                              ToolTip="{Binding I18n[common.language]}"
                              ItemsSource="{Binding I18n.AvailableLanguages}"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding I18n.SelectedCulture, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[settings.theme.title]}" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding I18n[settings.theme.body]}" Style="{StaticResource Faint}"
                               Margin="0,4,0,10" />
                    <ComboBox MinWidth="180" MaxWidth="260" HorizontalAlignment="Left"
                              VerticalContentAlignment="Center"
                              ToolTip="{Binding I18n[settings.theme.title]}"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedValuePath="Theme"
                              SelectedValue="{Binding SelectedTheme, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding ThemeStatusText}" Style="{StaticResource Faint}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,20">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[settings.about.title]}" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding I18n[settings.about.body]}" Style="{StaticResource Faint}"
                               Margin="0,4,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding I18n[settings.about.app]}"
                                   Style="{StaticResource Faint}" Margin="0,0,12,8" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding I18n[app.title]}"
                                   Foreground="{StaticResource Text}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding I18n[settings.about.version]}"
                                   Style="{StaticResource Faint}" Margin="0,0,12,8" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Version}"
                                   Foreground="{StaticResource Text}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding I18n[settings.about.license]}"
                                   Style="{StaticResource Faint}" Margin="0,0,12,8" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding License}"
                                   Foreground="{StaticResource Text}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding I18n[settings.about.repository]}"
                                   Style="{StaticResource Faint}" Margin="0,0,12,8" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                            <Hyperlink NavigateUri="{Binding RepositoryUrl}"
                                       RequestNavigate="ExternalLink_RequestNavigate">
                                <Run Text="{Binding I18n[settings.about.repositoryLink], Mode=OneWay}" />
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding I18n[settings.about.releases]}"
                                   Style="{StaticResource Faint}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="4" Grid.Column="1">
                            <Hyperlink NavigateUri="{Binding ReleasesUrl}"
                                       RequestNavigate="ExternalLink_RequestNavigate">
                                <Run Text="{Binding I18n[settings.about.releasesLink], Mode=OneWay}" />
                            </Hyperlink>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
