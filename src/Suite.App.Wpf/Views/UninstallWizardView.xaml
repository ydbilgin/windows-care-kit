<UserControl x:Class="WindowsCareKit.App.Views.UninstallWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WindowsCareKit.App.ViewModels"
             xmlns:mvvm="clr-namespace:WindowsCareKit.App.Mvvm"
             xmlns:controls="clr-namespace:WindowsCareKit.App.Controls">
    <!-- The 4-beat uninstall wizard (PR-4). DataContext = an UninstallWizardViewModel. The whole control is
         collapsed until the wizard is open, so it sits as an overlay in UninstallView. -->
    <UserControl.Resources>
        <!-- Maps the int ScanDepthIndex to a bool for a RadioButton's IsChecked (one option per index). -->
        <mvvm:IndexEqualsConverter x:Key="IndexEq" />

        <!-- A scan-depth radio option rendered as a selectable evidence card. -->
        <Style x:Key="DepthOption" TargetType="RadioButton">
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{StaticResource Backup.Card}" BorderBrush="{StaticResource Backup.Line}"
                                BorderThickness="1" CornerRadius="8" Padding="13">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Backup.CardHi}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Backup.LineStrong}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Backup.EmBorder}" />
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Backup.EmWash}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Backup.Ink}" />
            <Setter Property="Background" Value="{StaticResource Backup.Card}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.LineStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Backup.CardHi}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Backup.Faint}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Foreground" Value="{StaticResource Backup.EmInk}" />
            <Setter Property="Background" Value="{StaticResource Backup.Primary.Background}" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.Primary.Border}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Backup.Primary.Hover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Backup.Primary.HoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A leftover node: a checkable row for the 3-tier registry tree / files list. The checkbox is
             present+enabled only for ProgramOwned (CanCheck), present+disabled for Shared, absent for Protected. -->
        <DataTemplate x:Key="LeftoverNodeTemplate" DataType="{x:Type vm:LeftoverNode}">
            <Border Padding="11,9" Margin="0,0,0,6" CornerRadius="9"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Backup.Row.Background}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Backup.Line}" />
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="18" Direction="270" ShadowDepth="4" Opacity="0.14" Color="#000000" />
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Backup.Row.Hover}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Backup.LineStrong}" />
                            </Trigger>
                            <!-- Protected rows take the protected evidence tint. -->
                            <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                <Setter Property="Background" Value="{StaticResource Backup.EmWash}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Backup.EmBorder}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ProgramOwned/Shared render a checkbox (Shared's IsEnabled=false); Protected renders a shield. -->
                    <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,1,10,0"
                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                              IsEnabled="{Binding CanCheck}"
                              Visibility="{Binding HasCheckbox, Converter={StaticResource BoolToVis}}"
                              Checked="OnNodeCheckChanged" Unchecked="OnNodeCheckChanged" />
                    <TextBlock Grid.Column="0" Text="🛡" FontSize="13" Foreground="{StaticResource Backup.Em}"
                               VerticalAlignment="Top" Margin="0,0,10,0"
                               Visibility="{Binding HasCheckbox, Converter={StaticResource InverseBoolToVis}}" />

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding TargetText}" Foreground="{Binding TargetBrush}"
                                   FontWeight="{Binding TargetWeight}" FontSize="12.5"
                                   FontFamily="Cascadia Mono, Consolas, monospace" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SubText}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5"
                                   TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Sub-tab buttons (Registry / Files): neutral buttons + an active-state highlight driven by the bound
             IsRegistryTab / IsFilesTab so the selected sub-tab reads as active (fix #7). -->
        <Style x:Key="RegistryTabButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRegistryTab}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Backup.EmWash}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Backup.EmBorder}" />
                    <Setter Property="Foreground" Value="{StaticResource Backup.Em}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FilesTabButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFilesTab}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Backup.EmWash}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Backup.EmBorder}" />
                    <Setter Property="Foreground" Value="{StaticResource Backup.Em}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- One step-rail dot. -->
        <Style x:Key="StepDot" TargetType="Border">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource Backup.LineStrong}" />
            <Setter Property="Background" Value="{StaticResource Backup.Card}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <!-- Scrim + centered wizard card. Collapsed entirely when the wizard is closed. -->
    <Grid Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
        <Border Background="{StaticResource Bg.Scrim.Wizard}" />
        <Border Background="{StaticResource Backup.Card}" BorderBrush="{StaticResource Backup.LineStrong}"
                BorderThickness="1" CornerRadius="10" Width="780" MaxHeight="640"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" Direction="270" ShadowDepth="5" Opacity="0.22" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ===== Step rail (4 beats) ===== -->
                <Border Grid.Row="0" Background="{StaticResource Backup.Chrome}" BorderBrush="{StaticResource Backup.Line}"
                        BorderThickness="0,0,0,1" CornerRadius="10,10,0,0" Padding="24,14">
                    <StackPanel Orientation="Horizontal">
                        <!-- 1 Hazırlık -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource Backup.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.prep]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource Backup.Faint}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Backup.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPrepBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Backup.Em}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="26" Height="1" Background="{StaticResource Backup.Line}" Margin="10,0" VerticalAlignment="Center" />
                        <!-- 2 Tarama -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold" Foreground="{StaticResource Backup.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.scan]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Backup.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScanBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Backup.Em}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="26" Height="1" Background="{StaticResource Backup.Line}" Margin="10,0" VerticalAlignment="Center" />
                        <!-- 3 Kalıntılar -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold" Foreground="{StaticResource Backup.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.leftovers]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Backup.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLeftoversBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Backup.Em}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="26" Height="1" Background="{StaticResource Backup.Line}" Margin="10,0" VerticalAlignment="Center" />
                        <!-- 4 Sonuç -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold" Foreground="{StaticResource Backup.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.result]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Backup.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsResultBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Backup.Em}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== App summary ===== -->
                <Border Grid.Row="1" Background="{StaticResource Backup.CardHi}" BorderBrush="{StaticResource Backup.Line}"
                        BorderThickness="0,0,0,1" Padding="24,13">
                    <StackPanel>
                        <TextBlock Text="{Binding AppTitle}" FontSize="14.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Backup.Ink}" />
                        <TextBlock Text="{Binding AppMeta}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- ===== Beat body ===== -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,16">
                    <Grid>
                        <!-- ===== BEAT 1: Hazırlık & Resmî kaldırıcı ===== -->
                        <StackPanel Visibility="{Binding IsPrepBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding I18n[uninstall.wizard.prep.title]}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource Backup.Ink}" FontSize="16" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding I18n[uninstall.wizard.prep.subtitle]}" Style="{StaticResource Muted}"
                                       Foreground="{StaticResource Backup.Muted}" FontSize="13" Margin="0,5,0,16" TextWrapping="Wrap" />

                            <!-- Restore-point toggle: ENABLED only when SR is available (PR-5). When unavailable the
                                 row is dimmed and the checkbox disabled, keeping the honest reason. The reason text
                                 binds to RestorePointReason (available vs. needs-admin/SR-off). -->
                            <Border Background="{StaticResource Backup.Row.Background}" BorderBrush="{StaticResource Backup.Line}"
                                    BorderThickness="1" CornerRadius="8" Padding="14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1.0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RestorePointAvailable}" Value="False">
                                                <Setter Property="Opacity" Value="0.62" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding RestorePointEnabled, Mode=TwoWay}"
                                              IsEnabled="{Binding RestorePointAvailable}" VerticalAlignment="Top"
                                              Margin="0,2,12,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.prep.restorePoint.title]}"
                                                   Foreground="{StaticResource Backup.Ink}" FontSize="13.5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.prep.restorePoint.desc]}"
                                                   Foreground="{StaticResource Backup.Faint}" FontSize="11.5" TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding RestorePointReason}"
                                                   Foreground="{StaticResource Backup.MedFg}" FontSize="11.5"
                                                   Margin="0,5,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Honest rollback framing: .reg backup (adapter-internal) + Recycle Bin. -->
                            <Border Background="{StaticResource Backup.EmWash}" BorderBrush="{StaticResource Backup.EmBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="12,11" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="{Binding I18n[uninstall.wizard.prep.honest]}"
                                               Foreground="{StaticResource Backup.OkFg}" FontSize="11.5" TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <!-- Broken-uninstaller honest note. -->
                            <Border Background="{StaticResource Backup.MedWash}" BorderBrush="{StaticResource Backup.MedBorder}" BorderThickness="1" CornerRadius="8"
                                    Padding="11,9" Margin="0,14,0,0"
                                    Visibility="{Binding OfficialUnavailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding I18n[uninstall.wizard.official.unavailable]}"
                                           Foreground="{StaticResource Backup.MedFg}" FontSize="12" TextWrapping="Wrap" />
                            </Border>

                            <!-- Live status line during the official run. -->
                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                                <Border Height="6" CornerRadius="4" Background="{StaticResource Bg.Progress.Track}">
                                    <Border Background="{StaticResource Backup.Em}" Width="120" HorizontalAlignment="Left"
                                            CornerRadius="4" />
                                </Border>
                                <TextBlock Margin="0,9,0,0" TextWrapping="Wrap">
                                    <Run Text="{Binding I18n[uninstall.wizard.statusPrefix], Mode=OneWay}"
                                         Foreground="{StaticResource Backup.Muted}" />
                                    <Run Text="{Binding StatusLine, Mode=OneWay}" Foreground="{StaticResource Backup.Em}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- ===== BEAT 2: Tarama (scan depth) ===== -->
                        <StackPanel Visibility="{Binding IsScanBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding I18n[uninstall.wizard.scan.title]}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource Backup.Ink}" FontSize="16" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding I18n[uninstall.wizard.scan.subtitle]}" Style="{StaticResource Muted}"
                                       Foreground="{StaticResource Backup.Muted}" FontSize="13" Margin="0,5,0,16" TextWrapping="Wrap" />

                            <UniformGrid Columns="3">
                                <!-- Quick -->
                                <RadioButton GroupName="depth" IsChecked="{Binding ScanDepthIndex, Converter={StaticResource IndexEq}, ConverterParameter=0}"
                                             Style="{StaticResource DepthOption}" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.quick]}" Foreground="{StaticResource Backup.Ink}" FontWeight="SemiBold" FontSize="13.5" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.quick.desc]}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                </RadioButton>
                                <!-- Standard (recommended) -->
                                <RadioButton GroupName="depth" IsChecked="{Binding ScanDepthIndex, Converter={StaticResource IndexEq}, ConverterParameter=1}"
                                             Style="{StaticResource DepthOption}" Margin="5,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.standard]}" Foreground="{StaticResource Backup.Ink}" FontWeight="SemiBold" FontSize="13.5" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.standard.desc]}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.recommended]}" Foreground="{StaticResource Backup.Em}" FontSize="10.5" FontWeight="Bold" Margin="0,6,0,0" />
                                    </StackPanel>
                                </RadioButton>
                                <!-- Deep -->
                                <RadioButton GroupName="depth" IsChecked="{Binding ScanDepthIndex, Converter={StaticResource IndexEq}, ConverterParameter=2}"
                                             Style="{StaticResource DepthOption}" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.deep]}" Foreground="{StaticResource Backup.Ink}" FontWeight="SemiBold" FontSize="13.5" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.deep.desc]}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                </RadioButton>
                            </UniformGrid>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                                <Border Height="6" CornerRadius="4" Background="{StaticResource Bg.Progress.Track}">
                                    <Border Background="{StaticResource Backup.Em}" Width="120" HorizontalAlignment="Left" CornerRadius="4" />
                                </Border>
                                <TextBlock Margin="0,9,0,0" TextWrapping="Wrap">
                                    <Run Text="{Binding I18n[uninstall.wizard.statusPrefix], Mode=OneWay}" Foreground="{StaticResource Backup.Muted}" />
                                    <Run Text="{Binding StatusLine, Mode=OneWay}" Foreground="{StaticResource Backup.Em}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- ===== BEAT 3: Kalıntılar (3-tier registry tree + files) ===== -->
                        <StackPanel Visibility="{Binding IsLeftoversBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding I18n[uninstall.wizard.leftovers.title]}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource Backup.Ink}" FontSize="16" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding I18n[uninstall.wizard.leftovers.subtitle]}" Style="{StaticResource Muted}"
                                       Foreground="{StaticResource Backup.Muted}" FontSize="13" Margin="0,5,0,12" TextWrapping="Wrap" />

                            <!-- Sub-tabs: Registry / Files (active tab highlighted via IsRegistryTab/IsFilesTab). -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Command="{Binding ShowRegistryTabCommand}" Style="{StaticResource RegistryTabButton}"
                                        Padding="13,6" FontSize="12.5">
                                    <Button.Content>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.tab.registry]}" />
                                    </Button.Content>
                                </Button>
                                <Button Command="{Binding ShowFilesTabCommand}" Style="{StaticResource FilesTabButton}"
                                        Padding="13,6" FontSize="12.5" Margin="8,0,0,0">
                                    <Button.Content>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.tab.files]}" />
                                    </Button.Content>
                                </Button>
                            </StackPanel>

                            <!-- Helper -->
                            <Border Background="{StaticResource Backup.EmWash}" BorderBrush="{StaticResource Backup.EmBorder}" BorderThickness="1"
                                    CornerRadius="8" Padding="11,9" Margin="0,0,0,12">
                                <TextBlock Text="{Binding I18n[uninstall.wizard.helper]}" Foreground="{StaticResource Backup.OkFg}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </Border>

                            <!-- Fail-loud build-guard error (normally unreachable): amber, non-destructive, never green. -->
                            <Border Background="{StaticResource Backup.MedWash}" BorderBrush="{StaticResource Backup.MedBorder}" BorderThickness="1" CornerRadius="8"
                                    Padding="11,9" Margin="0,0,0,12"
                                    Visibility="{Binding HasBuildError, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding BuildError}" Foreground="{StaticResource Backup.MedFg}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </Border>

                            <!-- Select-all bar (ProgramOwned only) -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Command="{Binding SelectAllOwnedCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="11.5" FontWeight="Normal"
                                        Content="{Binding I18n[uninstall.wizard.selectAll]}" />
                                <TextBlock Grid.Column="1" Text="{Binding I18n[uninstall.wizard.selectAll.scope]}"
                                           Foreground="{StaticResource Backup.Faint}" FontSize="11.5" VerticalAlignment="Center" Margin="9,0,0,0" />
                                <TextBlock Grid.Column="2" Text="{Binding SelectionSummary}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Registry tab: the 3-tier node list -->
                            <Border Visibility="{Binding IsRegistryTab, Converter={StaticResource BoolToVis}}"
                                    Background="{StaticResource Backup.CardHi}" BorderBrush="{StaticResource Backup.Line}"
                                    BorderThickness="1" CornerRadius="8" Padding="10">
                                <ItemsControl ItemsSource="{Binding RegistryNodes}" ItemTemplate="{StaticResource LeftoverNodeTemplate}" />
                            </Border>

                            <!-- Files tab: same selectable rules + Recycle-Bin note -->
                            <StackPanel Visibility="{Binding IsFilesTab, Converter={StaticResource BoolToVis}}">
                                <Border Background="{StaticResource Backup.CardHi}" BorderBrush="{StaticResource Backup.Line}"
                                        BorderThickness="1" CornerRadius="8" Padding="10">
                                    <ItemsControl ItemsSource="{Binding FileNodes}" ItemTemplate="{StaticResource LeftoverNodeTemplate}" />
                                </Border>
                                <TextBlock Text="{Binding I18n[uninstall.wizard.files.recycleNote]}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5"
                                           Margin="2,8,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- ===== BEAT 4: Sonuç ===== -->
                        <StackPanel Visibility="{Binding IsResultBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ResultSummary}" Style="{StaticResource H2}" Foreground="{StaticResource Backup.Ink}" FontSize="16"
                                       TextWrapping="Wrap" />

                            <!-- Result rows -->
                            <ItemsControl ItemsSource="{Binding ExecutionResults}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Backup.Row.Background}" BorderBrush="{StaticResource Backup.Line}"
                                                BorderThickness="1" CornerRadius="8" Padding="13,9" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding RiskBrush}" BorderBrush="{Binding RiskBrush}"
                                                        BorderThickness="1" CornerRadius="999" Padding="7,2"
                                                        VerticalAlignment="Top" Margin="0,1,9,0">
                                                    <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10" FontWeight="Bold" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Text}" Foreground="{StaticResource Backup.Ink}" FontSize="13"
                                                               FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Detail}" Foreground="{StaticResource Backup.Faint}" FontSize="11.5"
                                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- SafetyGate-protected lines -->
                            <ItemsControl ItemsSource="{Binding ProtectedLines}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="🛡" Foreground="{StaticResource Backup.Em}" FontSize="13" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource Backup.OkFg}" FontSize="12.5" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Honest System-Restore-unavailable line -->
                            <Border Background="{StaticResource Backup.EmWash}" BorderBrush="{StaticResource Backup.EmBorder}" BorderThickness="1"
                                    CornerRadius="8" Padding="12,11" Margin="0,14,0,0">
                                <TextBlock Text="{Binding I18n[uninstall.wizard.result.restoreNote]}"
                                           Foreground="{StaticResource Backup.OkFg}" FontSize="12" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- ===== Footer (per-beat actions) ===== -->
                <Border Grid.Row="3" Background="{StaticResource Backup.Chrome}" BorderBrush="{StaticResource Backup.Line}"
                        BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Padding="24,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Cancel (always, except the result beat) -->
                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" FontWeight="Normal"
                                Content="{Binding I18n[uninstall.wizard.cancel]}" Command="{Binding CloseCommand}"
                                Visibility="{Binding IsResultBeat, Converter={StaticResource InverseBoolToVis}}" />

                        <!-- Right: beat-specific primary actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <!-- Beat 1: official uninstaller (ConfirmGate #1) + skip-to-scan for broken uninstaller.
                                 SkipToScanCommand is enabled in the Prep beat (ScanCommand would be permanently
                                 disabled here — its CanExecute requires the Scan beat). -->
                            <Button Style="{StaticResource SecondaryButton}" FontWeight="Normal" Margin="0,0,8,0"
                                    Content="{Binding I18n[uninstall.wizard.skipToScan]}" Command="{Binding SkipToScanCommand}"
                                    IsEnabled="{Binding CanSkipToScan}"
                                    Visibility="{Binding OfficialUnavailable, Converter={StaticResource BoolToVis}}" />
                            <Button Style="{StaticResource PrimaryButton}"
                                    Content="{Binding I18n[uninstall.wizard.runOfficial]}" Command="{Binding RunOfficialCommand}"
                                    IsEnabled="{Binding CanRunOfficial}"
                                    Visibility="{Binding IsPrepBeat, Converter={StaticResource BoolToVis}}" />

                            <!-- Beat 2: Back + Scan -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsScanBeat, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource SecondaryButton}" FontWeight="Normal" Margin="0,0,8,0"
                                        Content="{Binding I18n[uninstall.wizard.back]}" Command="{Binding BackCommand}" />
                                <Button Style="{StaticResource PrimaryButton}" Content="{Binding I18n[uninstall.wizard.scan.run]}"
                                        Command="{Binding ScanCommand}" IsEnabled="{Binding CanScan}" />
                            </StackPanel>

                            <!-- Beat 3: Back + Next-without-deleting + Delete-selected (ConfirmGate #2) -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsLeftoversBeat, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource SecondaryButton}" FontWeight="Normal" Margin="0,0,8,0"
                                        Content="{Binding I18n[uninstall.wizard.back]}" Command="{Binding BackCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" FontWeight="Normal" Margin="0,0,8,0"
                                        Content="{Binding I18n[uninstall.wizard.nextWithoutDeleting]}"
                                        Command="{Binding NextWithoutDeletingCommand}" />
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="{Binding I18n[uninstall.wizard.deleteSelected]}"
                                        Command="{Binding DeleteSelectedCommand}" IsEnabled="{Binding HasCheckedLeftovers}" />
                            </StackPanel>

                            <!-- Beat 4: Finish -->
                            <Button Style="{StaticResource PrimaryButton}" Content="{Binding I18n[uninstall.wizard.finish]}"
                                    Command="{Binding CloseCommand}"
                                    Visibility="{Binding IsResultBeat, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- The wizard's OWN ConfirmGate (ConfirmGate #1 official + #2 leftovers reuse), on top of the card. -->
        <controls:ConfirmGate DataContext="{Binding Gate}" />
    </Grid>
</UserControl>
