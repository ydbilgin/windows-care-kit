<UserControl x:Class="WindowsCareKit.App.Views.UninstallWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WindowsCareKit.App.ViewModels"
             xmlns:mvvm="clr-namespace:WindowsCareKit.App.Mvvm"
             xmlns:controls="clr-namespace:WindowsCareKit.App.Controls">
    <!-- The 4-beat uninstall wizard (PR-4). DataContext = an UninstallWizardViewModel. The whole control is
         collapsed until the wizard is open, so it sits as an overlay in UninstallView. -->
    <UserControl.Resources>
        <!-- Teal (SafetyGate-protected) + amber tones not already in the theme. -->
        <SolidColorBrush x:Key="Teal" Color="#7FC2A8" />
        <SolidColorBrush x:Key="Amber" Color="#E8B36B" />

        <!-- Maps the int ScanDepthIndex to a bool for a RadioButton's IsChecked (one option per index). -->
        <mvvm:IndexEqualsConverter x:Key="IndexEq" />

        <!-- A scan-depth radio option rendered as a selectable card (gold border when selected). -->
        <Style x:Key="DepthOption" TargetType="RadioButton">
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" BorderBrush="{StaticResource Border.Soft}"
                                BorderThickness="1" CornerRadius="10" Padding="13">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Border.Gold}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter TargetName="Bd" Property="Background" Value="#241F14" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A leftover node: a checkable row for the 3-tier registry tree / files list. The checkbox is
             present+enabled only for ProgramOwned (CanCheck), present+disabled for Shared, absent for Protected. -->
        <DataTemplate x:Key="LeftoverNodeTemplate" DataType="{x:Type vm:LeftoverNode}">
            <Border Padding="11,9" Margin="0,0,0,6" CornerRadius="9"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Bg.PanelAlt}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Border.Soft}" />
                        <Style.Triggers>
                            <!-- Protected rows take a teal-tinted background. -->
                            <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                <Setter Property="Background" Value="#16201C" />
                                <Setter Property="BorderBrush" Value="#22332D" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ProgramOwned/Shared render a checkbox (Shared's IsEnabled=false); Protected renders a shield. -->
                    <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,1,10,0"
                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                              IsEnabled="{Binding CanCheck}"
                              Visibility="{Binding HasCheckbox, Converter={StaticResource BoolToVis}}"
                              Checked="OnNodeCheckChanged" Unchecked="OnNodeCheckChanged" />
                    <TextBlock Grid.Column="0" Text="🛡" FontSize="13" Foreground="{StaticResource Teal}"
                               VerticalAlignment="Top" Margin="0,0,10,0"
                               Visibility="{Binding HasCheckbox, Converter={StaticResource InverseBoolToVis}}" />

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding TargetText}" Foreground="{Binding TargetBrush}"
                                   FontWeight="{Binding TargetWeight}" FontSize="12.5"
                                   FontFamily="Cascadia Mono, Consolas, monospace" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SubText}" Style="{StaticResource Faint}" Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Sub-tab buttons (Registry / Files): GhostButton + an active-state highlight driven by the bound
             IsRegistryTab / IsFilesTab so the selected sub-tab reads as active (fix #7). -->
        <Style x:Key="RegistryTabButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRegistryTab}" Value="True">
                    <Setter Property="Background" Value="#2E2614" />
                    <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                    <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FilesTabButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFilesTab}" Value="True">
                    <Setter Property="Background" Value="#2E2614" />
                    <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                    <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- One step-rail dot. -->
        <Style x:Key="StepDot" TargetType="Border">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource Border.Soft}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <!-- Scrim + centered wizard card. Collapsed entirely when the wizard is closed. -->
    <Grid Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
        <Border Background="#D80C0805" />
        <Border Background="{StaticResource Bg.Card}" BorderBrush="{StaticResource Border.Gold}"
                BorderThickness="1" CornerRadius="14" Width="780" MaxHeight="640"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ===== Step rail (4 beats) ===== -->
                <Border Grid.Row="0" Background="#1C1810" BorderBrush="{StaticResource Border.Soft}"
                        BorderThickness="0,0,0,1" CornerRadius="14,14,0,0" Padding="22,14">
                    <StackPanel Orientation="Horizontal">
                        <!-- 1 Hazırlık -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource Text.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.prep]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource Text.Faint}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Text.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPrepBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="26" Height="1" Background="{StaticResource Border.Soft}" Margin="10,0" VerticalAlignment="Center" />
                        <!-- 2 Tarama -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold" Foreground="{StaticResource Text.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.scan]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Text.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScanBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="26" Height="1" Background="{StaticResource Border.Soft}" Margin="10,0" VerticalAlignment="Center" />
                        <!-- 3 Kalıntılar -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold" Foreground="{StaticResource Text.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.leftovers]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Text.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLeftoversBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="26" Height="1" Background="{StaticResource Border.Soft}" Margin="10,0" VerticalAlignment="Center" />
                        <!-- 4 Sonuç -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepDot}">
                                <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="Bold" Foreground="{StaticResource Text.Faint}" />
                            </Border>
                            <TextBlock Text="{Binding I18n[uninstall.wizard.step.result]}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Text.Faint}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsResultBeat}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== App summary ===== -->
                <Border Grid.Row="1" Background="{StaticResource Bg.PanelAlt}" BorderBrush="{StaticResource Border.Soft}"
                        BorderThickness="0,0,0,1" Padding="26,13">
                    <StackPanel>
                        <TextBlock Text="{Binding AppTitle}" FontSize="14.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}" />
                        <TextBlock Text="{Binding AppMeta}" Style="{StaticResource Faint}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- ===== Beat body ===== -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="26,16">
                    <Grid>
                        <!-- ===== BEAT 1: Hazırlık & Resmî kaldırıcı ===== -->
                        <StackPanel Visibility="{Binding IsPrepBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding I18n[uninstall.wizard.prep.title]}" Style="{StaticResource H2}"
                                       FontSize="16" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding I18n[uninstall.wizard.prep.subtitle]}" Style="{StaticResource Muted}"
                                       Margin="0,5,0,16" TextWrapping="Wrap" />

                            <!-- Restore-point toggle: PRESENT but DISABLED with an honest reason (PR-5 activates). -->
                            <Border Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                                    BorderThickness="1" CornerRadius="10" Padding="14" Opacity="0.62">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding RestorePointEnabled, Mode=OneWay}"
                                              IsEnabled="{Binding RestorePointAvailable}" VerticalAlignment="Top"
                                              Margin="0,2,12,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.prep.restorePoint.title]}"
                                                   Foreground="{StaticResource Text}" FontSize="13.5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.prep.restorePoint.desc]}"
                                                   Style="{StaticResource Faint}" Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.prep.restorePoint.reason]}"
                                                   Foreground="{StaticResource Amber}" FontSize="11.5"
                                                   Margin="0,5,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Honest rollback framing: .reg backup (adapter-internal) + Recycle Bin. -->
                            <Border Background="#1D1810" BorderBrush="{StaticResource Border.Soft}"
                                    BorderThickness="1" CornerRadius="0,8,8,0" Padding="12,11" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="2" Background="{StaticResource Gold.Dim}" Margin="0,0,11,0" />
                                    <TextBlock Grid.Column="1" Text="{Binding I18n[uninstall.wizard.prep.honest]}"
                                               Foreground="{StaticResource Gold.Dim}" FontSize="11.5" TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <!-- Broken-uninstaller honest note. -->
                            <Border Background="#241F12" BorderBrush="#54472A" BorderThickness="1" CornerRadius="8"
                                    Padding="11,9" Margin="0,14,0,0"
                                    Visibility="{Binding OfficialUnavailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding I18n[uninstall.wizard.official.unavailable]}"
                                           Foreground="{StaticResource Amber}" FontSize="12" TextWrapping="Wrap" />
                            </Border>

                            <!-- Live status line during the official run. -->
                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                                <Border Height="6" CornerRadius="4" Background="#221D14">
                                    <Border Background="{StaticResource Gold}" Width="120" HorizontalAlignment="Left"
                                            CornerRadius="4" />
                                </Border>
                                <TextBlock Margin="0,9,0,0" TextWrapping="Wrap">
                                    <Run Text="{Binding I18n[uninstall.wizard.statusPrefix], Mode=OneWay}"
                                         Foreground="{StaticResource Text.Muted}" />
                                    <Run Text="{Binding StatusLine, Mode=OneWay}" Foreground="{StaticResource Gold.Bright}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- ===== BEAT 2: Tarama (scan depth) ===== -->
                        <StackPanel Visibility="{Binding IsScanBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding I18n[uninstall.wizard.scan.title]}" Style="{StaticResource H2}"
                                       FontSize="16" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding I18n[uninstall.wizard.scan.subtitle]}" Style="{StaticResource Muted}"
                                       Margin="0,5,0,16" TextWrapping="Wrap" />

                            <UniformGrid Columns="3">
                                <!-- Quick -->
                                <RadioButton GroupName="depth" IsChecked="{Binding ScanDepthIndex, Converter={StaticResource IndexEq}, ConverterParameter=0}"
                                             Style="{StaticResource DepthOption}" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.quick]}" FontWeight="SemiBold" FontSize="13.5" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.quick.desc]}" Style="{StaticResource Faint}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </RadioButton>
                                <!-- Standard (recommended) -->
                                <RadioButton GroupName="depth" IsChecked="{Binding ScanDepthIndex, Converter={StaticResource IndexEq}, ConverterParameter=1}"
                                             Style="{StaticResource DepthOption}" Margin="5,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.standard]}" FontWeight="SemiBold" FontSize="13.5" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.standard.desc]}" Style="{StaticResource Faint}" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.recommended]}" Foreground="{StaticResource Gold.Dim}" FontSize="10" Margin="0,6,0,0" />
                                    </StackPanel>
                                </RadioButton>
                                <!-- Deep -->
                                <RadioButton GroupName="depth" IsChecked="{Binding ScanDepthIndex, Converter={StaticResource IndexEq}, ConverterParameter=2}"
                                             Style="{StaticResource DepthOption}" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.deep]}" FontWeight="SemiBold" FontSize="13.5" />
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.depth.deep.desc]}" Style="{StaticResource Faint}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </RadioButton>
                            </UniformGrid>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                                <Border Height="6" CornerRadius="4" Background="#221D14">
                                    <Border Background="{StaticResource Gold}" Width="120" HorizontalAlignment="Left" CornerRadius="4" />
                                </Border>
                                <TextBlock Margin="0,9,0,0" TextWrapping="Wrap">
                                    <Run Text="{Binding I18n[uninstall.wizard.statusPrefix], Mode=OneWay}" Foreground="{StaticResource Text.Muted}" />
                                    <Run Text="{Binding StatusLine, Mode=OneWay}" Foreground="{StaticResource Gold.Bright}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- ===== BEAT 3: Kalıntılar (3-tier registry tree + files) ===== -->
                        <StackPanel Visibility="{Binding IsLeftoversBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding I18n[uninstall.wizard.leftovers.title]}" Style="{StaticResource H2}"
                                       FontSize="16" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding I18n[uninstall.wizard.leftovers.subtitle]}" Style="{StaticResource Muted}"
                                       Margin="0,5,0,12" TextWrapping="Wrap" />

                            <!-- Sub-tabs: Registry / Files (active tab highlighted via IsRegistryTab/IsFilesTab). -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Command="{Binding ShowRegistryTabCommand}" Style="{StaticResource RegistryTabButton}"
                                        Padding="13,6" FontSize="12.5">
                                    <Button.Content>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.tab.registry]}" />
                                    </Button.Content>
                                </Button>
                                <Button Command="{Binding ShowFilesTabCommand}" Style="{StaticResource FilesTabButton}"
                                        Padding="13,6" FontSize="12.5" Margin="8,0,0,0">
                                    <Button.Content>
                                        <TextBlock Text="{Binding I18n[uninstall.wizard.tab.files]}" />
                                    </Button.Content>
                                </Button>
                            </StackPanel>

                            <!-- Helper -->
                            <Border Background="#1D1810" BorderBrush="{StaticResource Border.Soft}" BorderThickness="1"
                                    CornerRadius="8" Padding="11,9" Margin="0,0,0,12">
                                <TextBlock Text="{Binding I18n[uninstall.wizard.helper]}" Foreground="{StaticResource Gold.Dim}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </Border>

                            <!-- Fail-loud build-guard error (normally unreachable): amber, non-destructive, never green. -->
                            <Border Background="#2A1C12" BorderBrush="#7A4B22" BorderThickness="1" CornerRadius="8"
                                    Padding="11,9" Margin="0,0,0,12"
                                    Visibility="{Binding HasBuildError, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding BuildError}" Foreground="{StaticResource Amber}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </Border>

                            <!-- Select-all bar (ProgramOwned only) -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Command="{Binding SelectAllOwnedCommand}"
                                        Style="{StaticResource GhostButton}" Padding="9,4" FontSize="11.5" FontWeight="Normal"
                                        Content="{Binding I18n[uninstall.wizard.selectAll]}" />
                                <TextBlock Grid.Column="1" Text="{Binding I18n[uninstall.wizard.selectAll.scope]}"
                                           Style="{StaticResource Faint}" VerticalAlignment="Center" Margin="9,0,0,0" />
                                <TextBlock Grid.Column="2" Text="{Binding SelectionSummary}" Style="{StaticResource Faint}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Registry tab: the 3-tier node list -->
                            <Border Visibility="{Binding IsRegistryTab, Converter={StaticResource BoolToVis}}"
                                    Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                                    BorderThickness="1" CornerRadius="10" Padding="10">
                                <ItemsControl ItemsSource="{Binding RegistryNodes}" ItemTemplate="{StaticResource LeftoverNodeTemplate}" />
                            </Border>

                            <!-- Files tab: same selectable rules + Recycle-Bin note -->
                            <StackPanel Visibility="{Binding IsFilesTab, Converter={StaticResource BoolToVis}}">
                                <Border Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Soft}"
                                        BorderThickness="1" CornerRadius="10" Padding="10">
                                    <ItemsControl ItemsSource="{Binding FileNodes}" ItemTemplate="{StaticResource LeftoverNodeTemplate}" />
                                </Border>
                                <TextBlock Text="{Binding I18n[uninstall.wizard.files.recycleNote]}" Style="{StaticResource Faint}"
                                           Margin="2,8,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- ===== BEAT 4: Sonuç ===== -->
                        <StackPanel Visibility="{Binding IsResultBeat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ResultSummary}" Style="{StaticResource H2}" FontSize="16"
                                       TextWrapping="Wrap" />

                            <!-- Result rows -->
                            <ItemsControl ItemsSource="{Binding ExecutionResults}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{Binding RiskBrush}" CornerRadius="4"
                                                    Padding="6,2" VerticalAlignment="Top" Margin="0,1,10,0">
                                                <TextBlock Text="{Binding RiskText}" Foreground="#181410" FontSize="10" FontWeight="Bold" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Text}" Foreground="{StaticResource Text}" FontSize="12.5" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Detail}" Style="{StaticResource Faint}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Teal SafetyGate-protected lines -->
                            <ItemsControl ItemsSource="{Binding ProtectedLines}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="🛡" Foreground="{StaticResource Teal}" FontSize="13" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource Teal}" FontSize="12.5" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Honest System-Restore-unavailable line -->
                            <Border Background="#1D1810" BorderBrush="{StaticResource Border.Soft}" BorderThickness="1"
                                    CornerRadius="8" Padding="12,11" Margin="0,14,0,0">
                                <TextBlock Text="{Binding I18n[uninstall.wizard.result.restoreNote]}"
                                           Foreground="{StaticResource Gold.Dim}" FontSize="12" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- ===== Footer (per-beat actions) ===== -->
                <Border Grid.Row="3" Background="#17120B" BorderBrush="{StaticResource Border.Soft}"
                        BorderThickness="0,1,0,0" CornerRadius="0,0,14,14" Padding="26,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Cancel (always, except the result beat) -->
                        <Button Grid.Column="0" Style="{StaticResource GhostButton}" FontWeight="Normal"
                                Content="{Binding I18n[uninstall.wizard.cancel]}" Command="{Binding CloseCommand}"
                                Visibility="{Binding IsResultBeat, Converter={StaticResource InverseBoolToVis}}" />

                        <!-- Right: beat-specific primary actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <!-- Beat 1: official uninstaller (ConfirmGate #1) + skip-to-scan for broken uninstaller.
                                 SkipToScanCommand is enabled in the Prep beat (ScanCommand would be permanently
                                 disabled here — its CanExecute requires the Scan beat). -->
                            <Button Style="{StaticResource GhostButton}" FontWeight="Normal" Margin="0,0,8,0"
                                    Content="{Binding I18n[uninstall.wizard.skipToScan]}" Command="{Binding SkipToScanCommand}"
                                    IsEnabled="{Binding CanSkipToScan}"
                                    Visibility="{Binding OfficialUnavailable, Converter={StaticResource BoolToVis}}" />
                            <Button Style="{StaticResource GhostButton}"
                                    Content="{Binding I18n[uninstall.wizard.runOfficial]}" Command="{Binding RunOfficialCommand}"
                                    IsEnabled="{Binding CanRunOfficial}"
                                    Visibility="{Binding IsPrepBeat, Converter={StaticResource BoolToVis}}" />

                            <!-- Beat 2: Back + Scan -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsScanBeat, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource GhostButton}" FontWeight="Normal" Margin="0,0,8,0"
                                        Content="{Binding I18n[uninstall.wizard.back]}" Command="{Binding BackCommand}" />
                                <Button Style="{StaticResource GhostButton}" Content="{Binding I18n[uninstall.wizard.scan.run]}"
                                        Command="{Binding ScanCommand}" IsEnabled="{Binding CanScan}" />
                            </StackPanel>

                            <!-- Beat 3: Back + Next-without-deleting + Delete-selected (ConfirmGate #2) -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsLeftoversBeat, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource GhostButton}" FontWeight="Normal" Margin="0,0,8,0"
                                        Content="{Binding I18n[uninstall.wizard.back]}" Command="{Binding BackCommand}" />
                                <Button Style="{StaticResource GhostButton}" FontWeight="Normal" Margin="0,0,8,0"
                                        Content="{Binding I18n[uninstall.wizard.nextWithoutDeleting]}"
                                        Command="{Binding NextWithoutDeletingCommand}" />
                                <Button Style="{StaticResource GhostButton}"
                                        Content="{Binding I18n[uninstall.wizard.deleteSelected]}"
                                        Command="{Binding DeleteSelectedCommand}" IsEnabled="{Binding HasCheckedLeftovers}" />
                            </StackPanel>

                            <!-- Beat 4: Finish -->
                            <Button Style="{StaticResource GhostButton}" Content="{Binding I18n[uninstall.wizard.finish]}"
                                    Command="{Binding CloseCommand}"
                                    Visibility="{Binding IsResultBeat, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- The wizard's OWN ConfirmGate (ConfirmGate #1 official + #2 leftovers reuse), on top of the card. -->
        <controls:ConfirmGate DataContext="{Binding Gate}" />
    </Grid>
</UserControl>
