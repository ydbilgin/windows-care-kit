<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ===== Theme palette (emerald safety system) ===== -->
    <SolidColorBrush x:Key="Bg.Window"   Color="#F6F7F9" />
    <SolidColorBrush x:Key="Bg.Panel"    Color="#FCFCFD" />
    <SolidColorBrush x:Key="Bg.PanelAlt" Color="#F3F5F9" />
    <SolidColorBrush x:Key="Bg.Card"     Color="#FDFDFE" />
    <SolidColorBrush x:Key="Bg.Scrim"    Color="#CCF6F7F9" />
    <SolidColorBrush x:Key="Bg.Scrim.Confirm" Color="#CCF6F7F9" />
    <SolidColorBrush x:Key="Bg.Scrim.Loading" Color="#AAF6F7F9" />
    <SolidColorBrush x:Key="Bg.Scrim.Wizard" Color="#D8F6F7F9" />
    <SolidColorBrush x:Key="Bg.Card.Alt" Color="#F3F5F9" />
    <SolidColorBrush x:Key="Bg.Card.Warning" Color="#FBF3DD" />
    <SolidColorBrush x:Key="Bg.Callout.Bad" Color="#FDF0EE" />
    <SolidColorBrush x:Key="Bg.Chrome.Rail" Color="#FCFCFD" />
    <SolidColorBrush x:Key="Bg.Footer" Color="#F6F7F9" />
    <SolidColorBrush x:Key="Bg.Gold.Subtle" Color="#E9F5EE" />
    <SolidColorBrush x:Key="Bg.Progress.Track" Color="#CCD3DD" />
    <SolidColorBrush x:Key="Bg.Protected" Color="#E9F5EE" />
    <SolidColorBrush x:Key="Bg.Row.Hover" Color="#F3F5F9" />
    <SolidColorBrush x:Key="Bg.Row.Selected" Color="#E9F5EE" />
    <SolidColorBrush x:Key="Bg.Status.Bad" Color="#FDF0EE" />
    <SolidColorBrush x:Key="Bg.Status.Good" Color="#E9F5EE" />
    <SolidColorBrush x:Key="Bg.Status.Warn" Color="#FBF3DD" />
    <SolidColorBrush x:Key="Bg.Warning.Strong" Color="#FDF0EE" />
    <SolidColorBrush x:Key="Border.Callout.Bad" Color="#F2C5BE" />
    <SolidColorBrush x:Key="Border.Card.Warning" Color="#EAD9A8" />
    <SolidColorBrush x:Key="Border.Protected" Color="#BFE0CD" />
    <SolidColorBrush x:Key="Border.Soft" Color="#E5E8EE" />
    <SolidColorBrush x:Key="Border.TopBar" Color="#E5E8EE" />
    <SolidColorBrush x:Key="Border.Gold" Color="#BFE0CD" />
    <SolidColorBrush x:Key="Code.Bg"     Color="#F3F5F9" />
    <SolidColorBrush x:Key="Code.Fg"     Color="#1C2330" />
    <SolidColorBrush x:Key="Gold"        Color="#0E7A54" />
    <SolidColorBrush x:Key="Gold.Bright" Color="#0E7A54" />
    <SolidColorBrush x:Key="Gold.Dim"    Color="#0B6142" />
    <SolidColorBrush x:Key="Text"        Color="#1C2330" />
    <SolidColorBrush x:Key="Text.Muted"  Color="#5C6675" />
    <SolidColorBrush x:Key="Text.Faint"  Color="#727C8C" />
    <SolidColorBrush x:Key="Text.Disabled" Color="#727C8C" />
    <SolidColorBrush x:Key="Success"     Color="#0E7A54" />
    <SolidColorBrush x:Key="Danger"      Color="#B42318" />
    <SolidColorBrush x:Key="Accent.Teal" Color="#0E7A54" />
    <SolidColorBrush x:Key="Accent.Amber" Color="#8A6210" />
    <SolidColorBrush x:Key="Bg.Input" Color="#FDFDFE" />
    <SolidColorBrush x:Key="ScrollBar.Track" Color="#E9EBEF" />
    <SolidColorBrush x:Key="ScrollBar.Thumb" Color="#CCD3DD" />
    <SolidColorBrush x:Key="ScrollBar.Thumb.Hover" Color="#727C8C" />
    <sys:Double x:Key="Opacity.Disabled.Button">0.45</sys:Double>
    <Color x:Key="Brand.Mark.Start">#17936A</Color>
    <Color x:Key="Brand.Mark.End">#0B6242</Color>

    <!-- ===== Backup slice tokens ===== -->
    <SolidColorBrush x:Key="Backup.Backdrop" Color="#E9EBEF" />
    <SolidColorBrush x:Key="Backup.Window.Border" Color="#CCD3DD" />
    <SolidColorBrush x:Key="Backup.Chrome" Color="#FCFCFD" />
    <SolidColorBrush x:Key="Backup.Card" Color="#FDFDFE" />
    <SolidColorBrush x:Key="Backup.CardHi" Color="#F3F5F9" />
    <SolidColorBrush x:Key="Backup.Line" Color="#E5E8EE" />
    <SolidColorBrush x:Key="Backup.LineStrong" Color="#CCD3DD" />
    <SolidColorBrush x:Key="Backup.Ink" Color="#1C2330" />
    <SolidColorBrush x:Key="Backup.Muted" Color="#5C6675" />
    <SolidColorBrush x:Key="Backup.Faint" Color="#8D95A3" />
    <SolidColorBrush x:Key="Backup.Em" Color="#0E7A54" />
    <SolidColorBrush x:Key="Backup.EmDeep" Color="#0B6142" />
    <SolidColorBrush x:Key="Backup.EmInk" Color="#F5FBF8" />
    <SolidColorBrush x:Key="Backup.EmWash" Color="#E9F5EE" />
    <SolidColorBrush x:Key="Backup.EmBorder" Color="#BFE0CD" />
    <SolidColorBrush x:Key="Backup.Primary.Border" Color="#0B6142" />
    <SolidColorBrush x:Key="Backup.Primary.HoverBorder" Color="#0E7A54" />
    <SolidColorBrush x:Key="Backup.OkFg" Color="#0E7A54" />
    <SolidColorBrush x:Key="Backup.OkWash" Color="#E9F5EE" />
    <SolidColorBrush x:Key="Backup.OkBorder" Color="#BFE0CD" />
    <SolidColorBrush x:Key="Backup.MedFg" Color="#8A6210" />
    <SolidColorBrush x:Key="Backup.MedWash" Color="#FBF3DD" />
    <SolidColorBrush x:Key="Backup.MedBorder" Color="#EAD9A8" />
    <SolidColorBrush x:Key="Backup.MedDot" Color="#D9A93E" />
    <SolidColorBrush x:Key="Backup.Danger" Color="#D92D20" />
    <SolidColorBrush x:Key="Backup.DangerDeep" Color="#B42318" />
    <SolidColorBrush x:Key="Backup.DangerStrong" Color="#B42318" />
    <SolidColorBrush x:Key="Backup.DangerText" Color="#FEF4F2" />
    <SolidColorBrush x:Key="Backup.DangerBorder" Color="#F2C5BE" />
    <SolidColorBrush x:Key="Backup.DangerBorderHover" Color="#E6A49B" />
    <SolidColorBrush x:Key="Backup.SkipChip" Color="#F6F7F9" />
    <SolidColorBrush x:Key="Backup.RailBorder" Color="#E5E8EE" />
    <SolidColorBrush x:Key="Backup.PathBg" Color="#F6F7F9" />
    <sys:Double x:Key="Backup.SkipRowOpacity">1.0</sys:Double>
    <LinearGradientBrush x:Key="Backup.Mark" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#17936A" Offset="0" />
        <GradientStop Color="#0B6242" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Backup.Primary.Background" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#12875E" Offset="0" />
        <GradientStop Color="#0D6F4C" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Backup.Primary.Hover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#179B6C" Offset="0" />
        <GradientStop Color="#0F7D56" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Backup.Row.Background" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FDFDFE" Offset="0" />
        <GradientStop Color="#FDFDFE" Offset="0.55" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Backup.Row.Hover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F3F5F9" Offset="0" />
        <GradientStop Color="#F3F5F9" Offset="0.55" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Backup.Row.Danger" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FDF0EE" Offset="0" />
        <GradientStop Color="#FDF0EE" Offset="0.55" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Backup.Rail.Background" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FDFDFE" Offset="0" />
        <GradientStop Color="#FDFDFE" Offset="0.6" />
    </LinearGradientBrush>

    <!-- ===== Text ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Gold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Muted" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Faint" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Text.Faint}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- ===== Ghost / gold buttons ===== -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Gold}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource Border.Gold}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F0E2C8" />
                            <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Text.Disabled}" />
                            <Setter Property="Opacity" Value="{StaticResource Opacity.Disabled.Button}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ComboBox (default style so every drop-down reads on the themed surface) ===== -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="row" Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="row" Property="Background" Value="{StaticResource Bg.PanelAlt}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="box" Background="{StaticResource Bg.PanelAlt}"
                                            BorderBrush="{StaticResource Border.Soft}" BorderThickness="1" CornerRadius="5">
                                        <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                                              Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource Text.Muted}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Border.Gold}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Margin="11,0,26,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          IsHitTestVisible="False" TextElement.Foreground="{StaticResource Text}" />
                        <Popup x:Name="PART_Popup" Placement="Bottom" Focusable="False" AllowsTransparency="True"
                               PopupAnimation="Fade" IsOpen="{TemplateBinding IsDropDownOpen}">
                            <Border Background="{StaticResource Bg.Card}" BorderBrush="{StaticResource Border.Soft}"
                                    BorderThickness="1" CornerRadius="5" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,3,0,0">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbRoot" Background="{StaticResource ScrollBar.Thumb}" CornerRadius="4" Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource ScrollBar.Thumb.Hover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource ScrollBar.Thumb.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10" />
        <Setter Property="MinWidth" Value="10" />
        <Setter Property="Background" Value="{StaticResource ScrollBar.Track}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="Root" Width="{TemplateBinding Width}" Height="Auto" Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton x:Name="DecreaseButton" Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource ScrollBarLineButton}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton x:Name="IncreaseButton" Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource ScrollBarLineButton}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto" />
                            <Setter Property="MinWidth" Value="0" />
                            <Setter Property="Height" Value="10" />
                            <Setter Property="MinHeight" Value="10" />
                            <Setter TargetName="Root" Property="Width" Value="Auto" />
                            <Setter TargetName="Root" Property="Height" Value="{Binding Height, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.PageLeftCommand}" />
                            <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.PageRightCommand}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Top module tab strip (horizontal nav) ===== -->
    <!-- Tabs wrap at narrower widths so the final Settings entry is never clipped. -->
    <Style x:Key="TopNavList" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- One module tab: glyph + bold label + one-line descriptor.
         Glyph + label brighten to gold when the parent ListBoxItem is selected (mockup .tab.active). -->
    <DataTemplate x:Key="TopNavModuleTemplate">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="18" VerticalAlignment="Center" Margin="0,0,11,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource Text.Muted}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Text}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Gold.Bright}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding Descriptor}" FontSize="10.5" Margin="0,1,0,0"
                           Foreground="{StaticResource Text.Faint}" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- The Settings tab: quiet, compact, icon + small label, far right. -->
    <DataTemplate x:Key="TopNavSettingsTemplate">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{StaticResource Text.Muted}" />
            <TextBlock Text="{Binding Title}" FontSize="12.5" VerticalAlignment="Center"
                       Foreground="{StaticResource Text.Muted}" />
        </StackPanel>
    </DataTemplate>

    <!-- Picks the module vs. settings inner template from NavItem.IsSettings. -->
    <Style x:Key="TopNavTab" TargetType="ListBoxItem">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ContentTemplate" Value="{StaticResource TopNavModuleTemplate}" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <!-- Bd carries hover/selected fill; Underline is the 2px gold active affordance. -->
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="9,9,0,0"
                            Padding="12,0" Margin="2,6,2,0" MinHeight="46" SnapsToDevicePixels="True">
                        <Border x:Name="Underline" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#EBDCC0" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Bg.PanelAlt}" />
                            <Setter TargetName="Underline" Property="BorderBrush" Value="{StaticResource Gold.Bright}" />
                        </Trigger>
                        <!-- Settings = quiet, compact template. -->
                        <DataTrigger Binding="{Binding IsSettings}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource TopNavSettingsTemplate}" />
                            <Setter TargetName="Bd" Property="Padding" Value="13,0" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== App list ===== -->
    <Style x:Key="AppList" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource Bg.Panel}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border.Soft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style x:Key="AppItem" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" BorderThickness="0,0,0,1"
                            BorderBrush="#E7D7BD" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E7D7BD" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F4DFAE" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Inputs ===== -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Bg.Input}" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="CaretBrush" Value="{StaticResource Gold}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border.Soft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Bg.Card}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border.Soft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
    </Style>
</ResourceDictionary>

