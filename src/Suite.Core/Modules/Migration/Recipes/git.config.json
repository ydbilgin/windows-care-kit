{
  "schemaVersion": 1,
  "id": "git.config",
  "displayName": "Git (.gitconfig)",
  "category": "dev-tools",
  "detect": { "knownFolder": "UserProfile", "path": ".gitconfig", "exists": true },
  "items": [
    { "path": ".gitconfig" }
  ],
  "exclude": [],
  "secretRule": "global",
  "portabilityClass": "profile-relative",
  "restore": {
    "strategy": "merge-after-install",
    "phase": "configWrite",
    "preconditions": []
  }
}
