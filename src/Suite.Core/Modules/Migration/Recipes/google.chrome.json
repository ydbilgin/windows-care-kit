{
  "schemaVersion": 3,
  "id": "google.chrome",
  "displayName": "Google Chrome",
  "category": "browsers",
  "detect": { "knownFolder": "LocalAppData", "path": "Google/Chrome/User Data", "exists": true },
  "items": [
    { "path": "Google/Chrome/User Data/Default/Preferences", "requiresClosedProcesses": ["chrome.exe"] },
    { "path": "Google/Chrome/User Data/Default/Bookmarks", "requiresClosedProcesses": ["chrome.exe"] }
  ],
  "exclude": ["Cookies", "Login Data", "Network", "Local State", "Safe Browsing*", "Cache", "Code Cache", "GPUCache"],
  "secretRule": "global",
  "portabilityClass": "machine-locked",
  "restore": { "strategy": "merge-after-install", "phase": "configWrite", "preconditions": ["process-closed"] },
  "install": { "method": "install-winget", "wingetId": "Google.Chrome" },
  "wingetId": "Google.Chrome",
  "productCode": [],
  "upgradeCode": [],
  "packageFamilyName": [],
  "installPathHint": ["Google Chrome", "Chrome"],
  "restoreTier": "merge-after-install",
  "catalogTier": "trusted",
  "migrationMeta": {
    "uiWarning": {
      "en": "Chrome app-bound encryption makes passwords, cookies, and sessions machine-locked; use sync or CSV export before format.",
      "tr": "Chrome app-bound encryption parola, cookie ve oturumlari makineye kilitler; format once sync veya CSV export kullan."
    },
    "manualTodo": ["Enable Chrome Sync or export passwords to CSV before formatting."],
    "installerSource": "winget",
    "licenseSource": "account-login",
    "requiresRelogin": true,
    "backedUpButNotRestored": true,
    "survivesOnOtherDrive": false
  }
}
