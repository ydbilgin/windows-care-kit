{
  "schemaVersion": 3,
  "id": "libreoffice.libreoffice",
  "displayName": "LibreOffice",
  "category": "office",
  "detect": { "knownFolder": "AppData", "path": "LibreOffice/4/user", "exists": true },
  "items": [
    { "path": "LibreOffice/4/user/config" },
    { "path": "LibreOffice/4/user/template" },
    { "path": "LibreOffice/4/user/autotext" },
    { "path": "LibreOffice/4/user/registrymodifications.xcu", "verify": { "exists": ["registrymodifications.xcu"], "maxSizeMB": 20 } }
  ],
  "exclude": ["cache", "backup"],
  "secretRule": "global",
  "portabilityClass": "profile-relative",
  "restore": { "strategy": "merge-after-install", "phase": "configWrite", "preconditions": ["process-closed"] },
  "install": { "method": "install-winget", "wingetId": "TheDocumentFoundation.LibreOffice" },
  "wingetId": "TheDocumentFoundation.LibreOffice",
  "productCode": [],
  "upgradeCode": [],
  "packageFamilyName": [],
  "installPathHint": ["LibreOffice"],
  "restoreTier": "merge-after-install",
  "catalogTier": "trusted",
  "upstreamDataLicense": "none",
  "migrationMeta": {
    "uiWarning": {
      "en": "Copies LibreOffice user profile; extensions or Java-dependent features may need separate reinstall.",
      "tr": "LibreOffice kullanici profilini kopyalar; extension veya Java bagimli ozellikler ayri kurulum isteyebilir."
    },
    "manualTodo": ["Reinstall extensions if LibreOffice reports them missing."],
    "installerSource": "winget",
    "licenseSource": "none",
    "requiresRelogin": false,
    "backedUpButNotRestored": false,
    "survivesOnOtherDrive": false
  }
}
