<UserControl x:Class="WindowsCareKit.App.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvvm="clr-namespace:WindowsCareKit.App.Mvvm;assembly=Suite.App.Abstractions">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <mvvm:PositiveToVisibleConverter x:Key="PositiveToVis" />
        <mvvm:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="BackupRowBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Backup.Row.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="13,9" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" Direction="270" ShadowDepth="4" Opacity="0.18" Color="#000000" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Backup.Row.Hover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Backup.LineStrong}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BackupManualRowBorder" TargetType="Border" BasedOn="{StaticResource BackupRowBorder}">
            <Setter Property="Background" Value="{DynamicResource Backup.Row.Danger}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.DangerBorder}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Backup.DangerBorderHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BackupSkippedRowBorder" TargetType="Border" BasedOn="{StaticResource BackupRowBorder}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Opacity" Value="{DynamicResource Backup.SkipRowOpacity}" />
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>

        <Style x:Key="BackupSectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Backup.Faint}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        </Style>

        <Style x:Key="BackupMetaText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Backup.Faint}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="BackupSecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Backup.Ink}" />
            <Setter Property="Background" Value="{DynamicResource Backup.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.LineStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Backup.CardHi}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Backup.Faint}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{DynamicResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackupPrimaryButton" TargetType="Button" BasedOn="{StaticResource BackupSecondaryButton}">
            <Setter Property="Foreground" Value="{DynamicResource Backup.EmInk}" />
            <Setter Property="Background" Value="{DynamicResource Backup.Primary.Background}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Backup.Primary.Border}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Backup.Primary.Hover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Backup.Primary.HoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{DynamicResource Opacity.Disabled.Button}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackupApproveCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Backup.Ink}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box" Width="15" Height="15" CornerRadius="3"
                                    Background="{DynamicResource Backup.Card}"
                                    BorderBrush="{DynamicResource Backup.EmBorder}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Data="M3,7 L6,10 L12,4"
                                      Stroke="{DynamicResource Backup.EmInk}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="10,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Backup.Em}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Backup.Em}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Backup.EmDeep}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="{DynamicResource Opacity.Disabled.Button}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CopyRowTemplate">
            <Border Style="{StaticResource BackupRowBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource Backup.OkWash}"
                                BorderBrush="{DynamicResource Backup.OkBorder}" BorderThickness="1"
                                CornerRadius="999" Padding="7,2" Margin="0,1,9,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding RiskText}" Foreground="{DynamicResource Backup.OkFg}"
                                       FontSize="10" FontWeight="Bold" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Text}" Foreground="{DynamicResource Backup.Ink}"
                                   FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{Binding Detail}" Style="{StaticResource BackupMetaText}"
                               Margin="0,4,0,0"
                               Visibility="{Binding Detail.Length, Converter={StaticResource PositiveToVis}}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ResultRowTemplate">
            <Border Style="{StaticResource BackupRowBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{Binding RiskBrush}"
                                BorderBrush="{Binding RiskBrush}" BorderThickness="1"
                                CornerRadius="999" Padding="7,2" Margin="0,1,9,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding RiskText}" Foreground="#181410"
                                       FontSize="10" FontWeight="Bold" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Text}" Foreground="{DynamicResource Backup.Ink}"
                                   FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{Binding Detail}" Style="{StaticResource BackupMetaText}"
                               Margin="0,4,0,0"
                               Visibility="{Binding Detail.Length, Converter={StaticResource PositiveToVis}}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ManualRowTemplate">
            <Border Style="{StaticResource BackupManualRowBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource Backup.MedWash}"
                                BorderBrush="{DynamicResource Backup.MedBorder}" BorderThickness="1"
                                CornerRadius="999" Padding="7,2" Margin="0,1,9,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding DataContext.I18n[backup.row.medChip], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="{DynamicResource Backup.MedFg}"
                                       FontSize="10" FontWeight="Bold" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Text}" Foreground="{DynamicResource Backup.Ink}"
                                   FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <Border Grid.Column="2" Background="{DynamicResource Backup.Danger}"
                                BorderBrush="{DynamicResource Backup.DangerDeep}" BorderThickness="1"
                                CornerRadius="6" Padding="9,2.5" Margin="10,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding DataContext.I18n[backup.row.cantCarry], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="{DynamicResource Backup.DangerText}"
                                       FontSize="11" FontWeight="Bold" />
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{Binding Detail}" Style="{StaticResource BackupMetaText}"
                               Margin="0,4,0,0"
                               Visibility="{Binding Detail.Length, Converter={StaticResource PositiveToVis}}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SkippedRowTemplate">
            <Border Style="{StaticResource BackupSkippedRowBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource Backup.SkipChip}"
                                BorderBrush="{DynamicResource Backup.Line}" BorderThickness="1"
                                CornerRadius="999" Padding="7,2" Margin="0,1,9,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding DataContext.I18n[backup.row.skipChip], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="{DynamicResource Backup.Faint}"
                                       FontSize="10" FontWeight="Bold" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Text}" Foreground="{DynamicResource Backup.Muted}"
                                   FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{Binding Detail}" Style="{StaticResource BackupMetaText}"
                               Margin="0,4,0,0"
                               Visibility="{Binding Detail.Length, Converter={StaticResource PositiveToVis}}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24,14,24,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,2">
                <TextBlock Text="{Binding I18n[backup.title]}" Foreground="{DynamicResource Backup.Ink}"
                           FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Border Background="{DynamicResource Backup.EmWash}"
                        BorderBrush="{DynamicResource Backup.EmBorder}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="12,4"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource Backup.Em}" Margin="0,0,8,0" />
                        <TextBlock Foreground="{DynamicResource Backup.Em}" FontSize="10.5" FontWeight="Bold">
                            <Run Text="{Binding I18n[backup.dryRun.badge], Mode=OneWay}" />
                            <Run Text="{Binding I18n[backup.dryRun.caption], Mode=OneWay}"
                                 Foreground="{DynamicResource Backup.Muted}" FontSize="11" FontWeight="Normal" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
            <TextBlock Text="{Binding I18n[backup.subtitle]}" Foreground="{DynamicResource Backup.Muted}"
                       FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PayloadDir, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource Backup.Card}"
                         Foreground="{DynamicResource Backup.Ink}"
                         BorderBrush="{DynamicResource Backup.LineStrong}"
                         BorderThickness="1"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12.5"
                         Padding="12,9"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource BackupPrimaryButton}"
                        Content="{Binding I18n[backup.scan]}" Command="{Binding BuildPlanCommand}" />
                <Button Grid.Column="2" Margin="9,0,0,0" Style="{StaticResource BackupSecondaryButton}"
                        Content="{Binding I18n[backup.run]}" Command="{Binding ApproveAndRunCommand}" />
            </Grid>
            <TextBlock Foreground="{DynamicResource Backup.Faint}" FontSize="11.5" Margin="2,0,0,0"
                       Text="{Binding I18n[backup.chooseDir]}" />
            <TextBlock Text="{Binding PayloadWarning}" Foreground="{DynamicResource Backup.DangerStrong}"
                       FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap"
                       Visibility="{Binding PayloadWarning.Length, Converter={StaticResource PositiveToVis}}" />

            <Border Background="{DynamicResource Backup.EmWash}"
                    BorderBrush="{DynamicResource Backup.EmBorder}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="14,10"
                    Margin="0,10,0,0"
                    Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" IsChecked="{Binding IsPreviewApproved}"
                              Style="{StaticResource BackupApproveCheckBox}"
                              Content="{Binding I18n[backup.approve]}" />
                    <Grid Grid.Column="2" Width="190" Height="6" Margin="18,0,14,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="39*" />
                            <ColumnDefinition Width="16*" />
                            <ColumnDefinition Width="24*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource Backup.Em}" CornerRadius="3,0,0,3" />
                        <Border Grid.Column="1" Background="{DynamicResource Backup.MedDot}" />
                        <Border Grid.Column="2" Background="{DynamicResource Backup.LineStrong}" CornerRadius="0,3,3,0" />
                    </Grid>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource Backup.Em}" Margin="0,0,6,0" />
                        <TextBlock Foreground="{DynamicResource Backup.Muted}" FontSize="12.5" Margin="0,0,14,0">
                            <Run Text="{Binding PlanRows.Count, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource Backup.Ink}" />
                            <Run Text="{Binding I18n[backup.count.toCopy], Mode=OneWay}" />
                        </TextBlock>
                        <Rectangle Width="7" Height="7" Fill="{DynamicResource Backup.MedDot}" RadiusX="2" RadiusY="2" Margin="0,0,6,0" />
                        <TextBlock Foreground="{DynamicResource Backup.Muted}" FontSize="12.5" Margin="0,0,14,0">
                            <Run Text="{Binding ManualRows.Count, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource Backup.Ink}" />
                            <Run Text="{Binding I18n[backup.count.manual], Mode=OneWay}" />
                        </TextBlock>
                        <Rectangle Width="7" Height="7" Fill="{DynamicResource Backup.LineStrong}" RadiusX="2" RadiusY="2" Margin="0,0,6,0" />
                        <TextBlock Foreground="{DynamicResource Backup.Muted}" FontSize="12.5">
                            <Run Text="{Binding SkippedRows.Count, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource Backup.Ink}" />
                            <Run Text="{Binding I18n[backup.count.skipped], Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="292" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,2,0">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[backup.empty.prompt]}" Foreground="{DynamicResource Backup.Muted}"
                               FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center"
                               Margin="0,40,0,0" MaxWidth="420" TextAlignment="Center"
                               Visibility="{Binding HasPlan, Converter={StaticResource InverseBoolToVis}}" />

                    <Grid Margin="2,2,2,7" Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding I18n[backup.report.title]}" Style="{StaticResource BackupSectionLabel}" />
                        <TextBlock Grid.Column="1" Text="{Binding PlanRows.Count, Mode=OneWay}" Style="{StaticResource BackupSectionLabel}"
                                   Margin="8,0,8,0" />
                        <Border Grid.Column="2" Height="1" Background="{DynamicResource Backup.Line}" VerticalAlignment="Center" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding PlanRows}" ItemTemplate="{StaticResource CopyRowTemplate}" />

                    <Grid Margin="2,11,2,7" Visibility="{Binding ManualRows.Count, Converter={StaticResource PositiveToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding I18n[backup.report.manual]}" Style="{StaticResource BackupSectionLabel}" />
                        <TextBlock Grid.Column="1" Text="{Binding ManualRows.Count, Mode=OneWay}" Style="{StaticResource BackupSectionLabel}"
                                   Margin="8,0,8,0" />
                        <Border Grid.Column="2" Height="1" Background="{DynamicResource Backup.Line}" VerticalAlignment="Center" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ManualRows}" ItemTemplate="{StaticResource ManualRowTemplate}" />

                    <Grid Margin="2,11,2,7" Visibility="{Binding SkippedRows.Count, Converter={StaticResource PositiveToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding I18n[backup.report.skipped]}" Style="{StaticResource BackupSectionLabel}" />
                        <TextBlock Grid.Column="1" Text="{Binding SkippedRows.Count, Mode=OneWay}" Style="{StaticResource BackupSectionLabel}"
                                   Margin="8,0,8,0" />
                        <Border Grid.Column="2" Height="1" Background="{DynamicResource Backup.Line}" VerticalAlignment="Center" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding SkippedRows}" ItemTemplate="{StaticResource SkippedRowTemplate}" />

                    <Grid Margin="2,18,2,7" Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding I18n[backup.report.copied]}" Style="{StaticResource BackupSectionLabel}" />
                        <Border Grid.Column="1" Height="1" Background="{DynamicResource Backup.Line}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ResultRows}" ItemTemplate="{StaticResource ResultRowTemplate}" />
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="{DynamicResource Backup.Rail.Background}"
                    BorderBrush="{DynamicResource Backup.RailBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16"
                    Margin="18,0,0,0"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="{Binding I18n[backup.summary.title]}" Foreground="{DynamicResource Backup.Ink}"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding I18n[backup.summary.toCopy]}" Foreground="{DynamicResource Backup.Muted}" FontSize="12.5" />
                        <TextBlock Grid.Column="1" Text="{Binding PlanRows.Count, Mode=OneWay}" Foreground="{DynamicResource Backup.Em}"
                                   FontSize="14" FontWeight="Bold" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource Backup.Line}" Margin="0,7,0,7" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding I18n[backup.summary.manual]}" Foreground="{DynamicResource Backup.Muted}" FontSize="12.5" />
                        <TextBlock Grid.Column="1" Text="{Binding ManualRows.Count, Mode=OneWay}" Foreground="{DynamicResource Backup.Ink}"
                                   FontSize="14" FontWeight="Bold" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource Backup.Line}" Margin="0,7,0,7" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding I18n[backup.summary.skipped]}" Foreground="{DynamicResource Backup.Muted}" FontSize="12.5" />
                        <TextBlock Grid.Column="1" Text="{Binding SkippedRows.Count, Mode=OneWay}" Foreground="{DynamicResource Backup.Ink}"
                                   FontSize="14" FontWeight="Bold" />
                    </Grid>

                    <TextBlock Text="{Binding I18n[backup.summary.destination]}" Foreground="{DynamicResource Backup.Faint}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,12,0,5" />
                    <Border Background="{DynamicResource Backup.PathBg}"
                            BorderBrush="{DynamicResource Backup.Line}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="9,7">
                        <TextBlock Text="{Binding PayloadDir}" Foreground="{DynamicResource Backup.Ink}"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="11.5" TextWrapping="Wrap" />
                    </Border>

                    <Border Background="{DynamicResource Backup.EmWash}"
                            BorderBrush="{DynamicResource Backup.EmBorder}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="11,9"
                            Margin="0,13,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="14" Height="14" Margin="0,1,8,0"
                                  Stretch="Uniform"
                                  Stroke="{DynamicResource Backup.OkFg}"
                                  StrokeThickness="1.8"
                                  Data="M12,3 L19,6 L19,12 C19,16 16,19 12,21 C8,19 5,16 5,12 L5,6 Z" />
                            <TextBlock Grid.Column="1" Foreground="{DynamicResource Backup.OkFg}"
                                       FontSize="11.5" TextWrapping="Wrap">
                                <Run Text="{Binding I18n[backup.summary.trustPrefix], Mode=OneWay}" />
                                <Run Text="{Binding I18n[backup.summary.trustStrong], Mode=OneWay}" FontWeight="Bold" />
                            </TextBlock>
                        </Grid>
                    </Border>

                    <TextBlock Foreground="{DynamicResource Backup.Faint}" FontSize="11.5"
                               TextWrapping="Wrap" Margin="0,11,0,0">
                        <Run Text="{Binding I18n[backup.summary.statusPrefix], Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource Backup.Muted}" />
                        <Run Text="{Binding I18n[backup.summary.statusDryRun], Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource Backup.Muted}"
                               FontSize="11.5" TextWrapping="Wrap" Margin="0,4,0,0"
                               Visibility="{Binding Summary.Length, Converter={StaticResource PositiveToVis}}" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding I18n[backup.footer]}"
                   Foreground="{DynamicResource Backup.Faint}"
                   FontSize="10.5"
                   TextAlignment="Center"
                   Padding="0,5,0,2" />
    </Grid>
</UserControl>
