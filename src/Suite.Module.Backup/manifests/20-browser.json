{
  "entries": [
    {
      "id": "firefox-profiles",
      "enabled": true,
      "profile": [
        "general",
        "dev"
      ],
      "phase": "backup",
      "category": "browser",
      "tier": "T2",
      "method": "copy",
      "source": "%APPDATA%\\Mozilla\\Firefox\\Profiles",
      "target": "browser/Firefox/Profiles",
      "include": [
        "places.sqlite",
        "prefs.js",
        "containers.json",
        "extensions/**"
      ],
      "exclude": [
        "cache2/**",
        "startupCache/**",
        "shader-cache/**",
        "thumbnails/**",
        "crashes/**",
        "minidumps/**",
        "safebrowsing/**"
      ],
      "requiresClosedProcesses": [
        "firefox"
      ],
      "secretHandling": "metadata-only",
      "verify": {
        "exists": [],
        "maxSizeMB": 1000
      },
      "restore": {
        "order": 50,
        "mode": "merge-after-install",
        "notes": "Restore after the related app is installed; review the generated report before copying back."
      },
      "description": "firefox-profiles: backs up the configured files into the payload while leaving cache and protected secret material excluded."
    },
